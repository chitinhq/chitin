{
  "name": "@chitin/adapter-ollama-local",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "nx": {
    "projectType": "library",
    "tags": [
      "type:adapter",
      "scope:plugin",
      "layer:adapter",
      "lang:ts",
      "runtime:local"
