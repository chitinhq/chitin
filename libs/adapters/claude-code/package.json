{
  "name": "@chitin/adapter-claude-code",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "sourceRoot": "libs/adapters/claude-code/src",
    "projectType": "library",
    "tags": [
      "type:adapter",
      "scope:plugin",
      "layer:adapter",
      "lang:ts"
    ],
    "targets": {
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -p libs/adapters/claude-code/tsconfig.json --noEmit",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "^validate"
        ]
      }
    }
  },
  "dependencies": {
    "@chitin/contracts": "workspace:*"
  }
}
