{
  "name": "@chitin/contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run tests",
    "generate-go-types": "tsx tools/generate-go-types.ts"
  },
  "nx": {
    "sourceRoot": "libs/contracts/src",
    "projectType": "library",
    "tags": [
      "type:lib",
      "scope:analytics",
      "layer:contracts",
      "lang:ts"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run libs/contracts/tests",
          "cwd": "{workspaceRoot}"
        }
      },
      "generate-go-types": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsx libs/contracts/tools/generate-go-types.ts",
          "cwd": "{workspaceRoot}"
        },
        "outputs": [
          "{workspaceRoot}/go/execution-kernel/internal/event/event.go"
        ]
      },
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -b libs/contracts/tsconfig.lib.json && pnpm exec vitest run libs/contracts/tests",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "^validate"
        ]
      }
    }
  },
  "dependencies": {}
}
