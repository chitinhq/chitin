{
  "name": "@chitin/run-sdk",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "description": "Standalone TypeScript SDK for emitting chitin-compatible run events without importing the execution kernel.",
  "license": "Apache-2.0",
  "scripts": {
    "test": "vitest run tests"
  },
  "nx": {
    "sourceRoot": "libs/run-sdk/src",
    "projectType": "library",
    "tags": [
      "type:lib",
      "scope:sdk",
      "layer:sdk",
      "lang:ts"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run libs/run-sdk/tests",
          "cwd": "{workspaceRoot}"
        }
      },
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -b libs/run-sdk/tsconfig.lib.json && pnpm exec vitest run libs/run-sdk/tests",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "^validate"
        ]
      }
    }
  },
  "dependencies": {
    "@chitin/contracts": "workspace:*"
  }
}
