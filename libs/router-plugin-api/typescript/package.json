{
  "name": "@chitin/router-plugin-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "description": "Opt-in side-effect gate for chitin router plugin authors. See index.ts for the gateAction() API.",
  "license": "MIT",
  "nx": {
    "projectType": "library",
    "tags": [
      "type:lib",
      "scope:plugin",
      "layer:plugin-api",
      "lang:ts"
    ],
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit",
          "cwd": "{projectRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run libs/router-plugin-api/typescript",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  }
}