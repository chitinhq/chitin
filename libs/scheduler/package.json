{
  "name": "@chitin/scheduler",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./notify/ntfy": {
      "import": "./src/notify/ntfy.ts",
      "default": "./src/notify/ntfy.ts"
    },
    "./notify/slack": {
      "import": "./src/notify/slack.ts",
      "default": "./src/notify/slack.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run tests"
  },
  "nx": {
    "tags": ["layer:scheduler", "scope:lib"],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run libs/scheduler/tests",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {
    "better-sqlite3": "*",
    "zod": "*"
  }
}
