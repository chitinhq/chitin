{
  "name": "@chitin/telemetry",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run tests"
  },
  "nx": {
    "tags": ["layer:telemetry"],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run libs/telemetry/tests",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {
    "@chitin/contracts": "workspace:*",
    "better-sqlite3": "*"
  }
}
