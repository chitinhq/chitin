{
  "name": "@chitin/telemetry",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run tests"
  },
  "nx": {
    "sourceRoot": "libs/telemetry/src",
    "projectType": "library",
    "tags": [
      "type:lib",
      "scope:analytics",
      "layer:telemetry",
      "lang:ts"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run libs/telemetry/tests",
          "cwd": "{workspaceRoot}"
        }
      },
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -b libs/telemetry/tsconfig.lib.json && pnpm exec vitest run libs/telemetry/tests",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "^validate"
        ]
      }
    }
  },
  "dependencies": {
    "@chitin/contracts": "workspace:*",
    "better-sqlite3": "*"
  }
}
