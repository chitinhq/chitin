#!/usr/bin/env bash
# Logs the invocation, emits a plan per the test's STUB_HERMES_PLAN_OUTPUT
# (for Stage 1), a diff for Stage 2, or a short act-log for Stage 3.
set -euo pipefail
echo "hermes $*" >> "${STUB_LOG:?STUB_LOG unset}"
[[ -n "${HERMES_TICK_DRY_RUN:-}" ]] && echo "HERMES_TICK_DRY_RUN=${HERMES_TICK_DRY_RUN}" >> "$STUB_LOG"
# Extract the -q value from argv (it immediately follows the flag).
query=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -q|--query) query="${2:-}"; shift 2 ;;
    *) shift ;;
  esac
done
case "$query" in
  *"Stage 1 (PLAN)"*) echo "${STUB_HERMES_PLAN_OUTPUT:-{\}}"; exit 0 ;;
  *"Stage 2 (CODE)"*) echo "${STUB_HERMES_CODE_OUTPUT:-}"; exit 0 ;;
  *"Stage 3 (ACT)"*)  echo "${STUB_HERMES_ACT_OUTPUT:-ok}"; exit 0 ;;
esac
exit 0
