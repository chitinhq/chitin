#!/usr/bin/env bash
# kanban-flow — lifecycle helper for the swarm SDLC.
#
# The Hermes kanban CLI exposes assign/comment/complete but not the
# in_progress / blocked transitions a real SDLC needs. This wrapper
# fills the gap: every status command does the flip AND the matching
# audit comment AND a task_events row.
#
# We deliberately do NOT use a `code_review` status. Hermes' kanban UI
# renders only triage/todo/ready/in_progress/blocked/done columns
# (hardcoded in hermes-agent; not configurable). A ticket flipped to
# code_review would vanish from the operator's board until merged,
# breaking kanban-as-source-of-truth. Tickets stay in in_progress
# while the PR is open; the PR's GitHub state is the review-phase
# truth. `kanban-flow pr` records the URL as a comment + event but
# does not move the ticket.
#
# Usage:
#   kanban-flow start <id> [--author NAME] [--worktree PATH]
#       triage|todo|ready → in_progress. Comments "picking up at <ts>".
#
#   kanban-flow pr <id> <pr-url> [--author NAME] [--event-chain-hash HASH]
#       in_progress stays. Comments with PR url + emits pr_opened event.
#
#   kanban-flow block <id> <reason...> [--author NAME]
#       any → blocked. Comments with reason.

#   kanban-flow crash <id> <reason...> [--author NAME] [--run-status STATUS]
#       [--outcome OUTCOME] [--event-chain-hash HASH] [--chain-file PATH]
#       in_progress → blocked. Finalizes the active task_run and comments
#       with the crash reason. STATUS defaults to crashed; accepts
#       crashed|failed|timed_out|blocked. --outcome defaults to STATUS.
#       --event-chain-hash / --chain-file record the worker's chain link.
#
#   kanban-flow unblock <id> [--author NAME] [--assignee NAME]
#       blocked → ready. Defaults assignee to clawta if no terminal lane
#       is already set and no explicit override is passed.
#
#   kanban-flow ready <id> [--author NAME] [--assignee NAME]
#       triage|blocked → ready. Defaults assignee to clawta if no terminal
#       lane is already set and no explicit override is passed.
#
#   kanban-flow demote <id> <reason...> [--author NAME]
#       ready|todo → triage. Comments with reason. Used by clawta when a
#       ticket isn't actually ready to dispatch.
#
#   kanban-flow done <id> --result "<summary>" [--session <chain-session-id>] [--author NAME]
#       in_progress → done. Comments with result, then posts a chain cost summary when a
#       matching session can be resolved.
#
#   kanban-flow status <id>
#       Print current status + last 5 transition comments.
#
#   kanban-flow comment <id> [--author NAME] <body...>
#       Record a task_comments row through the sanctioned write path.
#
#   kanban-flow assign <id> <assignee>
#       Update tasks.assignee through the sanctioned write path.
#
#   kanban-flow reassign <id> <assignee> [--author NAME] [--reason TEXT]
#       Update tasks.assignee and optionally leave an audit comment.
#
#   kanban-flow set-block-reason <id> <reason>
#       Update tasks.block_reason when the board schema exposes it.
#
#   kanban-flow record-failure <id> <failure-class> <reason...>
#       Increment tasks.consecutive_failures and stamp last_failure_error.
#
# Audit invariant: every status change emits both a task_comment AND a
# task_events row. Read either to reconstruct the lifecycle.

set -euo pipefail

BOARD="${KANBAN_BOARD:-chitin}"
_boards_dir="${HOME}/.hermes/kanban/boards"
if [[ -n "${KANBAN_DB:-}" ]]; then
  DB="$KANBAN_DB"
else
  DB="${_boards_dir}/${BOARD}/kanban.db"
fi
AUTHOR_DEFAULT="${HERMES_PROFILE:-${USER:-user}}"
CHITIN_HOME_DIR="${CHITIN_HOME:-$HOME/.chitin}"
DEFAULT_LEASE_SECONDS="${KANBAN_FLOW_LEASE_SECONDS:-3600}"
KANBAN_FLOW_APPLICATION_ID="${KANBAN_FLOW_APPLICATION_ID:-1262894167}"

is_terminal_lane() {
  local assignee="$1"
  [[ "$assignee" == "codex" || "$assignee" == "copilot" || "$assignee" == "claude-code" || "$assignee" == "gemini" || "$assignee" == "clawta" ]]
}

die() { echo "kanban-flow: $*" >&2; exit 2; }

usage() {
  sed -n '2,/^set -euo/p' "$0" | sed 's/^# \?//; /^set -euo/d'
}

require_id() {
  [[ "${1:-}" =~ ^t_[a-f0-9]+$ ]] || die "expected ticket id (t_XXXXXXXX), got: ${1:-<empty>}"
}

sql_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/''/g")"
}

write_sql() {
  local script="$1"
  shift || true
  sqlite3 "$DB" "$@" <<SQL
PRAGMA application_id = $KANBAN_FLOW_APPLICATION_ID;
CREATE TABLE IF NOT EXISTS kanban_mutations_log (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  ts INTEGER NOT NULL DEFAULT (strftime('%s','now')),
  table_name TEXT NOT NULL,
  op TEXT NOT NULL,
  task_id TEXT,
  application_id INTEGER,
  pid INTEGER
);
CREATE TABLE IF NOT EXISTS kanban_mutation_context (
  singleton INTEGER PRIMARY KEY CHECK (singleton = 1),
  pid INTEGER NOT NULL,
  application_id INTEGER NOT NULL
);
CREATE TRIGGER IF NOT EXISTS audit_tasks_insert
AFTER INSERT ON tasks
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'tasks',
    'INSERT',
    NEW.id,
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_tasks_update
AFTER UPDATE ON tasks
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'tasks',
    'UPDATE',
    COALESCE(NEW.id, OLD.id),
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_tasks_delete
AFTER DELETE ON tasks
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'tasks',
    'DELETE',
    OLD.id,
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_task_comments_insert
AFTER INSERT ON task_comments
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'task_comments',
    'INSERT',
    NEW.task_id,
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_task_comments_update
AFTER UPDATE ON task_comments
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'task_comments',
    'UPDATE',
    COALESCE(NEW.task_id, OLD.task_id),
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_task_comments_delete
AFTER DELETE ON task_comments
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'task_comments',
    'DELETE',
    OLD.task_id,
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_task_events_insert
AFTER INSERT ON task_events
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'task_events',
    'INSERT',
    NEW.task_id,
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_task_events_update
AFTER UPDATE ON task_events
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'task_events',
    'UPDATE',
    COALESCE(NEW.task_id, OLD.task_id),
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
CREATE TRIGGER IF NOT EXISTS audit_task_events_delete
AFTER DELETE ON task_events
BEGIN
  INSERT INTO kanban_mutations_log(table_name, op, task_id, application_id, pid)
  VALUES (
    'task_events',
    'DELETE',
    OLD.task_id,
    (SELECT application_id FROM kanban_mutation_context WHERE singleton = 1),
    (SELECT pid FROM kanban_mutation_context WHERE singleton = 1)
  );
END;
BEGIN IMMEDIATE;
INSERT INTO kanban_mutation_context(singleton, pid, application_id)
VALUES (1, $$, $KANBAN_FLOW_APPLICATION_ID)
ON CONFLICT(singleton) DO UPDATE
SET pid = excluded.pid,
    application_id = excluded.application_id;
$script
;
COMMIT;
SQL
}

ticket_status() {
  local id="$1"
  sqlite3 "$DB" "SELECT status FROM tasks WHERE id='$id'"
}

has_column() {
  local table="$1" column="$2"
  sqlite3 "$DB" "PRAGMA table_info($table)" | awk -F'|' -v col="$column" '$2 == col { found=1 } END { exit found ? 0 : 1 }'
}

ensure_task_runs_schema() {
  write_sql "
    CREATE TABLE IF NOT EXISTS task_runs (
      id                  INTEGER PRIMARY KEY AUTOINCREMENT,
      task_id             TEXT NOT NULL,
      profile             TEXT,
      step_key            TEXT,
      status              TEXT NOT NULL,
      claim_lock          TEXT,
      claim_expires       INTEGER,
      worker_pid          INTEGER,
      max_runtime_seconds INTEGER,
      last_heartbeat_at   INTEGER,
      started_at          INTEGER NOT NULL,
      ended_at            INTEGER,
      outcome             TEXT,
      summary             TEXT,
      metadata            TEXT,
      error               TEXT,
      model               TEXT NOT NULL DEFAULT '',
      soul_id             TEXT NOT NULL DEFAULT '',
      soul_hash           TEXT NOT NULL DEFAULT '',
      agent_fingerprint   TEXT NOT NULL DEFAULT ''
    );
    CREATE INDEX IF NOT EXISTS idx_runs_task   ON task_runs(task_id, started_at);
    CREATE INDEX IF NOT EXISTS idx_runs_status ON task_runs(status);
  "
  has_column task_runs driver_id || write_sql "ALTER TABLE task_runs ADD COLUMN driver_id TEXT"
  has_column task_runs repo_sha || write_sql "ALTER TABLE task_runs ADD COLUMN repo_sha TEXT"
  has_column task_runs lease_id || write_sql "ALTER TABLE task_runs ADD COLUMN lease_id TEXT"
  has_column task_runs event_chain_hash || write_sql "ALTER TABLE task_runs ADD COLUMN event_chain_hash TEXT"
  has_column task_runs idempotency_key || write_sql "ALTER TABLE task_runs ADD COLUMN idempotency_key TEXT"
  has_column task_runs model || write_sql "ALTER TABLE task_runs ADD COLUMN model TEXT NOT NULL DEFAULT ''"
  has_column task_runs soul_id || write_sql "ALTER TABLE task_runs ADD COLUMN soul_id TEXT NOT NULL DEFAULT ''"
  has_column task_runs soul_hash || write_sql "ALTER TABLE task_runs ADD COLUMN soul_hash TEXT NOT NULL DEFAULT ''"
  has_column task_runs agent_fingerprint || write_sql "ALTER TABLE task_runs ADD COLUMN agent_fingerprint TEXT NOT NULL DEFAULT ''"
}

resolve_worktree() {
  local id="$1"
  if [[ -n "$worktree" ]]; then
    printf '%s\n' "$worktree"
    return
  fi
  sqlite3 "$DB" "SELECT workspace_path FROM tasks WHERE id='$id'" 2>/dev/null | head -n1
}

repo_sha_for_worktree() {
  local candidate="$1"
  [[ -n "$candidate" && -d "$candidate" ]] || return 0
  git -C "$candidate" rev-parse HEAD 2>/dev/null || true
}

uuid4() {
  python3 - <<'PY'
import uuid
print(uuid.uuid4())
PY
}

resolve_driver_id() {
  python3 - "$CHITIN_HOME_DIR" <<'PY'
import hashlib
import json
import os
import pathlib
import pwd
import socket
import sys

chitin_home = pathlib.Path(sys.argv[1]).expanduser()
config_path = pathlib.Path(
    os.environ.get("CHITIN_DRIVER_IDENTITY_FILE", str(chitin_home / "driver_identity.json"))
).expanduser()
data = None
if config_path.is_file():
    try:
        payload = json.loads(config_path.read_text())
        if isinstance(payload, dict):
            data = payload.get("driver_identity") if isinstance(payload.get("driver_identity"), dict) else payload
    except Exception:
        data = None

uid = os.getuid()
hostname = socket.gethostname()
fallback_user = (
    os.environ.get("CHITIN_DRIVER_USER")
    or os.environ.get("USER")
    or pwd.getpwuid(uid).pw_name
)
fallback_machine_id = (
    os.environ.get("CHITIN_DRIVER_MACHINE_ID")
    or os.environ.get("HOSTNAME")
    or hostname
)
fallback_machine_fp = (
    os.environ.get("CHITIN_DRIVER_MACHINE_FINGERPRINT")
    or hashlib.sha256(f"{hostname}|{uid}|chitin-machine-fingerprint-v2".encode("utf-8")).hexdigest()
)

resolved = {
    "user": fallback_user,
    "machine_id": fallback_machine_id,
    "machine_fingerprint": fallback_machine_fp,
}
if isinstance(data, dict):
    resolved = {
        "user": str(data.get("user") or fallback_user),
        "machine_id": str(data.get("machine_id") or fallback_machine_id),
        "machine_fingerprint": str(data.get("machine_fingerprint") or fallback_machine_fp),
    }

print(json.dumps(resolved, separators=(",", ":"), sort_keys=True))
PY
}

task_field() {
  local id="$1" field="$2"
  # `|| true`: with `set -o pipefail`, a SELECT for a column an older `tasks`
  # schema doesn't have makes this pipeline non-zero and aborts the whole
  # script. Treat a missing/new column as simply "no value".
  sqlite3 "$DB" "SELECT $field FROM tasks WHERE id='$id'" 2>/dev/null | head -n1 || true
}

active_run_id() {
  local id="$1"
  local run_id
  run_id="$(sqlite3 "$DB" "SELECT current_run_id FROM tasks WHERE id='$id'" 2>/dev/null || true)"
  if [[ -n "$run_id" ]]; then
    printf '%s\n' "$run_id"
    return
  fi
  sqlite3 "$DB" "SELECT id FROM task_runs WHERE task_id='$id' AND status='running' ORDER BY started_at DESC, id DESC LIMIT 1"
}

maybe_sql_null() {
  local value="$1"
  if [[ -z "$value" ]]; then
    printf 'NULL'
  else
    printf "'%s'" "$(printf '%s' "$value" | sed "s/'/''/g")"
  fi
}

task_has_column() {
  has_column tasks "$1"
}

add_comment() {
  local id="$1" comment_author="$2" comment_body="$3"
  local now
  now="$(date +%s)"
  # Use sql_quote for all values — .parameter set with single-quoted
  # values breaks on embedded quotes/backticks in comment_body (the
  # bug that made `kanban-flow done` crash with NOT NULL constraint
  # on task_comments.body).
  write_sql "INSERT INTO task_comments (task_id, author, body, created_at)
     VALUES ($(sql_quote "$id"), $(sql_quote "$comment_author"), $(sql_quote "$comment_body"), $now)"
}

set_assignee() {
  local id="$1" assignee_value="$2"
  write_sql "UPDATE tasks SET assignee=$(sql_quote "$assignee_value") WHERE id=$(sql_quote "$id")"
}

set_block_reason() {
  local id="$1" block_reason_value="$2"
  task_has_column block_reason || return 0
  write_sql "UPDATE tasks SET block_reason=$(sql_quote "$block_reason_value") WHERE id=$(sql_quote "$id")"
}

record_failure_metadata() {
  local id="$1" failure_class="$2" reason_text="$3"
  local assignments=()
  task_has_column consecutive_failures && assignments+=("consecutive_failures=COALESCE(consecutive_failures, 0) + 1")
  task_has_column last_failure_error && assignments+=("last_failure_error=$(sql_quote "[$failure_class] $reason_text")")
  [[ "${#assignments[@]}" -gt 0 ]] || return 0
  local set_clause
  set_clause="$(IFS=,; printf '%s' "${assignments[*]}")"
  write_sql "UPDATE tasks SET $set_clause WHERE id=$(sql_quote "$id")"
}

infer_event_chain_hash() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    printf '%s\n' "$explicit"
    return
  fi
  local chain_file="${2:-}"
  if [[ -n "$chain_file" && -f "$chain_file" ]]; then
    python3 - "$chain_file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
last_hash = ""
try:
    for raw in path.read_text().splitlines():
        line = raw.strip()
        if not line:
            continue
        try:
            payload = json.loads(line)
        except json.JSONDecodeError:
            continue
        last_hash = str(payload.get("this_hash") or "") or last_hash
except OSError:
    pass
print(last_hash)
PY
  fi
}

create_task_run() {
  local id="$1"
  ensure_task_runs_schema

  local existing
  existing="$(sqlite3 "$DB" "SELECT id FROM task_runs WHERE task_id='$id' AND status IN ('running','blocked') AND ended_at IS NULL ORDER BY started_at DESC, id DESC LIMIT 1")"
  [[ -z "$existing" ]] || die "$id already has an incomplete task_run ($existing)"

  local now lease_id driver_id profile step_key task_idempotency max_runtime claim_expires worktree_path repo_sha model soul_id soul_hash agent_fingerprint
  now="$(date +%s)"
  lease_id="$(uuid4)"
  driver_id="$(resolve_driver_id)"
  model="${CHITIN_DISPATCH_MODEL:-${CHITIN_MODEL:-}}"
  soul_id="${CHITIN_DISPATCH_SOUL_ID:-${CHITIN_ACTIVE_SOUL:-}}"
  soul_hash="${CHITIN_DISPATCH_SOUL_HASH:-}"
  agent_fingerprint="${CHITIN_DISPATCH_AGENT_FINGERPRINT:-${CHITIN_AGENT_FINGERPRINT:-${CHITIN_FINGERPRINT:-}}}"
  profile="$(task_field "$id" assignee)"
  step_key="$(task_field "$id" current_step_key)"
  task_idempotency="$(task_field "$id" idempotency_key)"
  max_runtime="$(task_field "$id" max_runtime_seconds)"
  [[ -n "$max_runtime" ]] || max_runtime="$DEFAULT_LEASE_SECONDS"
  claim_expires=$((now + max_runtime))
  worktree_path="$(resolve_worktree "$id")"
  repo_sha="$(repo_sha_for_worktree "$worktree_path")"

  write_sql \
    "INSERT INTO task_runs (
       task_id, profile, step_key, status, claim_lock, claim_expires,
       max_runtime_seconds, last_heartbeat_at, started_at, lease_id,
       driver_id, repo_sha, model, soul_id, soul_hash, agent_fingerprint, idempotency_key
     ) VALUES (
       :task_id, NULLIF(:profile,''), NULLIF(:step_key,''), 'running', :lease_id, :claim_expires,
       :max_runtime, :now, :now, :lease_id,
       NULLIF(:driver_id,''), NULLIF(:repo_sha,''), :model, :soul_id, :soul_hash, :agent_fingerprint, NULLIF(:idempotency,'')
     );" \
    -cmd ".parameter set :task_id '$id'" \
    -cmd ".parameter set :profile '$profile'" \
    -cmd ".parameter set :step_key '$step_key'" \
    -cmd ".parameter set :lease_id '$lease_id'" \
    -cmd ".parameter set :driver_id '$driver_id'" \
    -cmd ".parameter set :repo_sha '$repo_sha'" \
    -cmd ".parameter set :model '$model'" \
    -cmd ".parameter set :soul_id '$soul_id'" \
    -cmd ".parameter set :soul_hash '$soul_hash'" \
    -cmd ".parameter set :agent_fingerprint '$agent_fingerprint'" \
    -cmd ".parameter set :idempotency '$task_idempotency'" \
    -cmd ".parameter set :now $now" \
    -cmd ".parameter set :claim_expires $claim_expires" \
    -cmd ".parameter set :max_runtime $max_runtime"

  local run_id
  run_id="$(sqlite3 "$DB" "SELECT id FROM task_runs WHERE task_id='$id' AND lease_id='$(printf '%s' "$lease_id" | sed "s/'/''/g")' ORDER BY id DESC LIMIT 1")"
  write_sql "
    UPDATE tasks
       SET claim_lock='$(printf '%s' "$lease_id" | sed "s/'/''/g")',
           claim_expires=$claim_expires,
           last_heartbeat_at=$now,
           current_run_id=$run_id
     WHERE id='$id'
  " 2>/dev/null || true
}

finalize_task_run() {
  local id="$1" run_status="$2" outcome="$3" summary="$4" error_text="$5"
  ensure_task_runs_schema

  local run_id now event_hash
  run_id="$(active_run_id "$id")"
  [[ -n "$run_id" ]] || return 0
  now="$(date +%s)"
  event_hash="$(infer_event_chain_hash "$event_chain_hash" "$chain_file")"

  write_sql "
    UPDATE task_runs
       SET status='$run_status',
           ended_at=$now,
           outcome=$(maybe_sql_null "$outcome"),
           summary=$(maybe_sql_null "$summary"),
           error=$(maybe_sql_null "$error_text"),
           event_chain_hash=COALESCE($(maybe_sql_null "$event_hash"), event_chain_hash)
     WHERE id=$run_id
  "
  write_sql "
    UPDATE tasks
       SET current_run_id=NULL,
           claim_lock=NULL,
           claim_expires=NULL
     WHERE id='$id'
  " 2>/dev/null || true
}

update_active_run_event_chain_hash() {
  local id="$1" hash_value
  hash_value="$(infer_event_chain_hash "$event_chain_hash" "$chain_file")"
  [[ -n "$hash_value" ]] || return 0
  local run_id
  run_id="$(active_run_id "$id")"
  [[ -n "$run_id" ]] || return 0
  write_sql "UPDATE task_runs SET event_chain_hash='$(printf '%s' "$hash_value" | sed "s/'/''/g")' WHERE id=$run_id"
}

stamp_active_run_identity() {
  local id="$1"
  ensure_task_runs_schema
  local run_id driver_json model soul_id soul_hash agent_fingerprint
  run_id="$(active_run_id "$id")"
  [[ -n "$run_id" ]] || return 0
  driver_json="${CHITIN_DRIVER_IDENTITY_JSON:-$(resolve_driver_id)}"
  model="${CHITIN_DISPATCH_MODEL:-${CHITIN_MODEL:-}}"
  soul_id="${CHITIN_DISPATCH_SOUL_ID:-${CHITIN_ACTIVE_SOUL:-}}"
  soul_hash="${CHITIN_DISPATCH_SOUL_HASH:-}"
  agent_fingerprint="${CHITIN_DISPATCH_AGENT_FINGERPRINT:-${CHITIN_AGENT_FINGERPRINT:-${CHITIN_FINGERPRINT:-}}}"

  write_sql \
    "UPDATE task_runs
        SET driver_id = COALESCE(NULLIF(:driver_id,''), driver_id),
            model = CASE WHEN :model != '' THEN :model ELSE model END,
            soul_id = CASE WHEN :soul_id != '' THEN :soul_id ELSE soul_id END,
            soul_hash = CASE WHEN :soul_hash != '' THEN :soul_hash ELSE soul_hash END,
            agent_fingerprint = CASE WHEN :agent_fingerprint != '' THEN :agent_fingerprint ELSE agent_fingerprint END
      WHERE id = :run_id" \
    -cmd ".parameter set :run_id $run_id" \
    -cmd ".parameter set :driver_id '$driver_json'" \
    -cmd ".parameter set :model '$model'" \
    -cmd ".parameter set :soul_id '$soul_id'" \
    -cmd ".parameter set :soul_hash '$soul_hash'" \
    -cmd ".parameter set :agent_fingerprint '$agent_fingerprint'"
}

assert_status() {
  local id="$1"; shift
  local cur; cur="$(ticket_status "$id")"
  for s in "$@"; do
    [[ "$cur" == "$s" ]] && return 0
  done
  die "$id status is '$cur'; expected one of: $*"
}

emit_transition() {
  # Args: id from to author [extra_json]
  # Use sql_quote for all values to avoid the same .parameter set
  # quoting bug that broke add_comment (single-quoted values break on
  # embedded quotes/backticks/special chars).
  local id="$1" from="$2" to="$3" author="$4" payload_extra="${5:-{\}}"
  local now; now="$(date +%s)"
  write_sql "INSERT INTO task_events (task_id, kind, payload, created_at)
     VALUES ($(sql_quote "$id"), 'status_transition',
             json_object('from', $(sql_quote "$from"), 'to', $(sql_quote "$to"), 'by', $(sql_quote "$author"), 'extra', json($(sql_quote "$payload_extra"))),
             $now)"
}

flip_status() {
  local id="$1" to="$2" set_started="${3:-0}" set_completed="${4:-0}"
  local now; now="$(date +%s)"
  local fields="status='$to'"
  [[ "$set_started" -eq 1 ]] && fields="$fields, started_at=COALESCE(started_at, $now)"
  [[ "$set_completed" -eq 1 ]] && fields="$fields, completed_at=$now"
  write_sql "UPDATE tasks SET $fields WHERE id='$id'"
}

cmd=${1:-}; shift || die "missing command (see kanban-flow --help)"
case "$cmd" in
  -h|--help) usage; exit 0 ;;
esac

# Parse common flags
author="$AUTHOR_DEFAULT"
worktree=""
assignee_override=""
session_id=""
event_chain_hash=""
chain_file=""
run_status_override=""
outcome_override=""
reason_override=""
force_flag=0
reclaim_flag=0
parse_flags() {
  local rest=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --author) author="$2"; shift 2 ;;
      --worktree) worktree="$2"; shift 2 ;;
      --result) result="$2"; shift 2 ;;
      --assignee) assignee_override="$2"; shift 2 ;;
      --session) session_id="$2"; shift 2 ;;
      --event-chain-hash) event_chain_hash="$2"; shift 2 ;;
      --chain-file) chain_file="$2"; shift 2 ;;
      --run-status) run_status_override="$2"; shift 2 ;;
      --outcome) outcome_override="$2"; shift 2 ;;
      --reason) reason_override="$2"; shift 2 ;;
      --reclaim) reclaim_flag=1; shift ;;
      --force) force_flag=1; shift ;;
      *) rest+=("$1"); shift ;;
    esac
  done
  REST=("${rest[@]+"${rest[@]}"}")
}

# Tracking-epic guard: matches `Tracking-epic: true|yes|1` at start of line
# in the ticket body, case-insensitive. Used by the `ready` subcommand to
# refuse auto-promotion of parent containers (see ticket t_6eba6ad2).
is_tracking_epic_id() {
  local id="$1"
  local body
  body=$(sqlite3 "$DB" "SELECT COALESCE(body,'') FROM tasks WHERE id='$id'" 2>/dev/null)
  [[ -n "$body" ]] && grep -qiE '^tracking-epic:[[:space:]]*(true|yes|1)[[:space:]]*$' <<< "$body"
}

post_cost_summary_comment() {
  local id="$1"
  local resolved_session="$2"
  local summary_json
  summary_json="$(chitin-kernel chain replay --session="$resolved_session" 2>/dev/null \
    | python3 -c 'import json,sys
try:
    data=json.load(sys.stdin)
    s=data.get("summary", {})
    out={
      "session_id": data.get("session_id",""),
      "total_cost_usd": float(s.get("total_cost_usd",0) or 0),
      "total_tokens": int(s.get("total_tokens",0) or 0),
      "dispatch_count": int(s.get("dispatch_count",0) or 0),
      "success_rate": float(s.get("success_rate",0) or 0),
    }
    print(json.dumps(out))
except Exception:
    sys.exit(1)')" || return 0
  [[ -n "$summary_json" ]] || return 0

  local body
  body="$(printf '%s' "$summary_json" | python3 -c 'import json,sys
d=json.load(sys.stdin)
print(
  (
    "Chain cost summary: "
    "session {session_id} | "
    "${total_cost_usd:.4f} | "
    "{total_tokens} tokens | "
    "{dispatch_count} dispatches | "
    "{success_pct:.1f}% success"
  ).format(success_pct=d["success_rate"]*100, **d)
)')" || return 0
  add_comment "$id" "$author" "$body"
}

case "$cmd" in
  start)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    assert_status "$id" triage todo ready in_progress
    from="$(ticket_status "$id")"
    body="Picking up at $(date -Iseconds)"
    [[ -n "$worktree" ]] && body="$body — worktree: $worktree"
    add_comment "$id" "$author" "$body"
    # create_task_run before flip_status: it die()s if an incomplete run
    # already exists, and we must not leave the ticket flipped to
    # in_progress with no run when that happens.
    create_task_run "$id"
    flip_status "$id" in_progress 1 0
    emit_transition "$id" "$from" in_progress "$author"
    echo "$id: $from → in_progress"
    ;;
  pr)
    parse_flags "$@"
    id="${REST[0]:-}"; url="${REST[1]:-}"; require_id "$id"
    [[ -n "$url" ]] || die "missing PR url"
    assert_status "$id" in_progress
    add_comment "$id" "$author" "PR opened: $url"
    # No status flip — Hermes UI has no code_review column, so we keep
    # the ticket in in_progress and let the PR's GitHub state be the
    # review-phase truth. Audit still records the PR via a pr_opened
    # event for downstream tooling.
    update_active_run_event_chain_hash "$id"
    pr_now="$(date +%s)"
    write_sql "INSERT INTO task_events (task_id, kind, payload, created_at)
       VALUES ($(sql_quote "$id"), 'pr_opened', json_object('pr_url', $(sql_quote "$url"), 'by', $(sql_quote "$author")), $pr_now)"
    echo "$id: in_progress (PR opened: $url)"
    ;;
  block)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    reason="${REST[*]:1}"
    [[ -n "$reason" ]] || die "missing reason"
    from="$(ticket_status "$id")"
    add_comment "$id" "$author" "Blocked: $reason"
    flip_status "$id" blocked 0 0
    if [[ "$from" == in_progress ]]; then
      finalize_task_run "$id" blocked blocked "" "$reason"
    fi
    emit_transition "$id" "$from" blocked "$author"
    echo "$id: $from → blocked ($reason)"
    ;;
  crash)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    reason="${REST[*]:1}"
    [[ -n "$reason" ]] || die "missing reason"
    from="$(ticket_status "$id")"
    add_comment "$id" "$author" "Crashed: $reason"
    flip_status "$id" blocked 0 0
    final_status="${run_status_override:-crashed}"
    case "$final_status" in
      crashed|failed|timed_out|blocked) ;;
      *) die "invalid --run-status: $final_status" ;;
    esac
    final_outcome="${outcome_override:-$final_status}"
    finalize_task_run "$id" "$final_status" "$final_outcome" "" "$reason"
    emit_transition "$id" "$from" blocked "$author"
    echo "$id: $from → blocked (crash: $reason)"
    ;;
  unblock)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    # Spec 025 atomicity invariant: take per-ticket flock before mutating.
    # If finalize_dispatch is in flight for this id, fail fast (exit 75);
    # cron retries on next tick. Lock auto-releases on this shell's exit.
    # spec: 025-dispatch-atomicity-invariant
    LOCKFILE="${HOME}/.chitin/locks/dispatch-${id}.lock"
    mkdir -p "$(dirname "$LOCKFILE")"
    exec {ATOMICITY_LOCKFD}>"$LOCKFILE"
    if ! flock -nE 75 "$ATOMICITY_LOCKFD"; then
        echo "kanban-flow unblock: $id lock held by concurrent finalize/unblock — retry next cron tick" >&2
        exit 75
    fi
    echo "$$" >&"$ATOMICITY_LOCKFD"
    assert_status "$id" blocked
    add_comment "$id" "$author" "Unblocked at $(date -Iseconds)"
    flip_status "$id" ready 0 0

    # Reset consecutive_failures — ticket was blocked and is now being re-dispatched
    task_has_column consecutive_failures && write_sql "UPDATE tasks SET consecutive_failures=0 WHERE id='$id'" 2>/dev/null || true

    # Handle assignee: always reset to routing lane on promotion so poller re-routes
    if [[ -z "$assignee_override" ]]; then
      set_assignee "$id" clawta
    elif [[ -n "$assignee_override" ]]; then
      set_assignee "$id" "$assignee_override"
    fi

    emit_transition "$id" blocked ready "$author"
    echo "$id: blocked → ready"
    ;;
  demote)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    reason="${REST[*]:1}"
    [[ -n "$reason" ]] || die "missing reason"
    assert_status "$id" ready todo
    from="$(ticket_status "$id")"
    add_comment "$id" "$author" "Demoted ${from}→triage: $reason"
    flip_status "$id" triage 0 0
    # Reset assignee to routing lane on demotion so re-promotion routes through clawta
    set_assignee "$id" clawta
    emit_transition "$id" "$from" triage "$author"
    echo "$id: $from → triage ($reason)"
    ;;
  ready)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    from="$(ticket_status "$id")"
    [[ "$from" == triage || "$from" == blocked ]] || die "$id is in '$from'; can only mark ready from triage|blocked"
    # Refuse to auto-promote tracking epics — they intentionally lack
    # invariants_and_boundaries + a terminal-lane assignee, and will spin
    # in a promote-demote loop with clawta-poller. Operator can override
    # with --force. See ticket t_6eba6ad2.
    if (( force_flag == 0 )) && is_tracking_epic_id "$id"; then
      die "$id is marked 'Tracking-epic: true' — auto-promotion blocked. Pass --force to override (operator-explicit promotion)."
    fi
    add_comment "$id" "$author" "Marked ready by $author at $(date -Iseconds)"
    flip_status "$id" ready 0 0

    # Reset consecutive_failures when re-dispatching a previously-blocked ticket —
    # mirrors the `unblock` path so the watchdog doesn't escalate prematurely.
    if [[ "$from" == blocked ]]; then
      task_has_column consecutive_failures && write_sql "UPDATE tasks SET consecutive_failures=0 WHERE id='$id'" 2>/dev/null || true
    fi

    # Handle assignee: always reset to routing lane on promotion so poller re-routes
    if [[ -z "$assignee_override" ]]; then
      set_assignee "$id" clawta
    elif [[ -n "$assignee_override" ]]; then
      set_assignee "$id" "$assignee_override"
    fi

    emit_transition "$id" "$from" ready "$author"
    echo "$id: $from → ready"
    ;;
  done)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    [[ -n "${result:-}" ]] || die "missing --result"
    from="$(ticket_status "$id")"
    add_comment "$id" "$author" "Done: $result"
    flip_status "$id" done 0 1
    write_sql "UPDATE tasks SET result='$(echo "$result" | sed "s/'/''/g")' WHERE id='$id'"
    # Reset consecutive_failures — task completed successfully
    task_has_column consecutive_failures && write_sql "UPDATE tasks SET consecutive_failures=0 WHERE id='$id'" 2>/dev/null || true
    finalize_task_run "$id" done "${outcome_override:-completed}" "$result" ""
    emit_transition "$id" "$from" done "$author"
    resolved_session="$session_id"
    if [[ -z "$resolved_session" ]] && command -v chitin-kernel >/dev/null 2>&1; then
      # Best-effort: a missing/failing chitin-kernel must not fail `done`.
      # Standalone assignment from a failed $() trips `set -e`, so guard with `|| true`.
      resolved_session="$(chitin-kernel chain sessions --ticket="$id" 2>/dev/null | head -1 | tr -d '\r')" || resolved_session=""
    fi
    if [[ -n "$resolved_session" ]]; then
      post_cost_summary_comment "$id" "$resolved_session"
    fi
    echo "$id: $from → done"
    ;;
  status)
    id="${1:-}"; require_id "$id"
    cur="$(ticket_status "$id")"
    echo "$id: $cur"
    echo "Last 5 transitions:"
    sqlite3 "$DB" "SELECT datetime(created_at,'unixepoch','localtime'), kind, payload FROM task_events WHERE task_id='$id' AND kind='status_transition' ORDER BY id DESC LIMIT 5"
    ;;
  stamp-run-identity)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    stamp_active_run_identity "$id"
    echo "$id: stamped run identity"
    ;;
  comment)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    body="${REST[*]:1}"
    [[ -n "$body" ]] || die "missing comment body"
    add_comment "$id" "$author" "$body"
    echo "$id: comment added"
    ;;
  assign)
    parse_flags "$@"
    id="${REST[0]:-}"; assignee="${REST[1]:-}"; require_id "$id"
    [[ -n "$assignee" ]] || die "missing assignee"
    set_assignee "$id" "$assignee"
    echo "$id: assignee -> $assignee"
    ;;
  reassign)
    parse_flags "$@"
    id="${REST[0]:-}"; assignee="${REST[1]:-}"; require_id "$id"
    [[ -n "$assignee" ]] || die "missing assignee"
    set_assignee "$id" "$assignee"
    if [[ -n "$reason_override" ]]; then
      add_comment "$id" "$author" "Reassigned to $assignee: $reason_override"
    fi
    echo "$id: reassigned -> $assignee"
    ;;
  set-block-reason)
    parse_flags "$@"
    id="${REST[0]:-}"; require_id "$id"
    block_reason="${REST[*]:1}"
    [[ -n "$block_reason" ]] || die "missing block reason"
    set_block_reason "$id" "$block_reason"
    echo "$id: block_reason -> $block_reason"
    ;;
  record-failure)
    parse_flags "$@"
    id="${REST[0]:-}"; failure_class="${REST[1]:-}"; require_id "$id"
    reason="${REST[*]:2}"
    [[ -n "$failure_class" ]] || die "missing failure class"
    [[ -n "$reason" ]] || die "missing failure reason"
    record_failure_metadata "$id" "$failure_class" "$reason"
    echo "$id: failure recorded ($failure_class)"
    ;;
  *)
    die "unknown command: $cmd (try kanban-flow --help)"
    ;;
esac
