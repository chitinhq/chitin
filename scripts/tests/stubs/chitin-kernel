#!/usr/bin/env bash
set -euo pipefail

# Shared test stub used by multiple script suites. Some tests assert raw
# kernel args, while agent-unlock asserts the executable-prefixed form.
if [[ -n "${STUB_KERNEL_LOG:-}" ]]; then
  echo "$*" >> "$STUB_KERNEL_LOG"
fi
if [[ -n "${STUB_LOG:-}" ]]; then
  echo "$*" >> "$STUB_LOG"
  echo "chitin-kernel $*" >> "$STUB_LOG"
fi

if [[ "${1:-}" == "envelope" && "${2:-}" == "list" ]]; then
  if [[ -n "${STUB_CHITIN_ENVELOPE_LIST_STDERR:-}" ]]; then
    printf '%s\n' "$STUB_CHITIN_ENVELOPE_LIST_STDERR" >&2
  fi
  printf '%s\n' "${STUB_CHITIN_ENVELOPE_LIST_OUTPUT:-[]}"
  exit "${STUB_CHITIN_ENVELOPE_LIST_RC:-0}"
fi

if [[ "${1:-}" == "envelope" && "${2:-}" == "create" ]]; then
  if [[ -n "${STUB_CHITIN_ENVELOPE_CREATE_STDERR:-}" ]]; then
    printf '%s\n' "$STUB_CHITIN_ENVELOPE_CREATE_STDERR" >&2
  fi
  printf '%s\n' "${STUB_CHITIN_ENVELOPE_CREATE_OUTPUT:-NEWENVDEFAULT}"
  exit "${STUB_CHITIN_ENVELOPE_CREATE_RC:-0}"
fi

if [[ "${1:-}" == "envelope" && "${2:-}" == "use" ]]; then
  if [[ -n "${STUB_CHITIN_ENVELOPE_USE_STDERR:-}" ]]; then
    printf '%s\n' "$STUB_CHITIN_ENVELOPE_USE_STDERR" >&2
  fi
  if [[ "${STUB_CHITIN_ENVELOPE_USE_WRITES_POINTER:-1}" == "1" ]]; then
    printf '%s\n' "${3:-}" > "$CHITIN_HOME/current-envelope"
  fi
  exit "${STUB_CHITIN_ENVELOPE_USE_RC:-0}"
fi

if [[ "${1:-}" == "emit" ]]; then
  if [[ -n "${STUB_EMIT_CAPTURE:-}" ]]; then
    for ((i = 1; i <= $#; i++)); do
      if [[ "${!i}" == "--event-file" ]]; then
        next=$((i + 1))
        cp "${!next}" "$STUB_EMIT_CAPTURE"
        break
      fi
    done
  fi
  exit "${STUB_KERNEL_EMIT_STATUS:-0}"
fi

if [[ "${1:-}" == "gate" && "${2:-}" == "reset" ]]; then
  exit "${STUB_KERNEL_RESET_STATUS:-0}"
fi

exit 0
