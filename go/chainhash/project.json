{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "chainhash-go",
  "root": "go/chainhash",
  "sourceRoot": "go/chainhash",
  "projectType": "library",
  "tags": ["type:lib", "scope:sdk", "layer:sdk", "lang:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/chainhash",
        "command": "go build ./..."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/chainhash",
        "command": "go test ./..."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/chainhash",
        "command": "go vet ./..."
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/chainhash",
        "command": "go vet ./... && go test ./..."
      },
      "dependsOn": ["^validate"]
    }
  }
}
