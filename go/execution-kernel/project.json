{
  "name": "execution-kernel",
  "root": "go/execution-kernel",
  "sourceRoot": "go/execution-kernel",
  "projectType": "application",
  "tags": ["type:app", "scope:kernel", "layer:kernel", "lang:go", "runtime:local"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/execution-kernel",
        "command": "go build -o ../../dist/go/execution-kernel/chitin-kernel ./cmd/chitin-kernel"
      },
      "outputs": ["{workspaceRoot}/dist/go/execution-kernel/chitin-kernel"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/execution-kernel",
        "command": "go test ./..."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/execution-kernel",
        "command": "go vet ./..."
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/execution-kernel",
        "command": "go run ./cmd/chitin-kernel"
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/execution-kernel",
        "command": "go vet ./... && go test ./..."
      },
      "dependsOn": ["^validate"]
    }
  }
}
