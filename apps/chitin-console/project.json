{
  "name": "chitin-console",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "cc",
  "sourceRoot": "apps/chitin-console/src",
  "tags": ["type:app", "scope:app", "layer:console", "lang:ts"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/chitin-console",
        "browser": "apps/chitin-console/src/main.ts",
        "tsConfig": "apps/chitin-console/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/chitin-console/public"
          }
        ],
        "styles": ["apps/chitin-console/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "proxyConfig": "apps/chitin-console/proxy.conf.json",
        "host": "127.0.0.1",
        "port": 4200
      },
      "configurations": {
        "production": {
          "buildTarget": "chitin-console:build:production"
        },
        "development": {
          "buildTarget": "chitin-console:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "chitin-console:build",
        "staticFilePath": "dist/apps/chitin-console/browser",
        "spa": true
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["echo 'validate passed'"],
        "parallel": false
      },
      "dependsOn": ["build", "^validate"]
    }
  }
}
