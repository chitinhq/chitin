{
  "name": "@chitin/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "nx": {
    "sourceRoot": "apps/chitin-dashboard/src",
    "projectType": "application",
    "tags": [
      "type:app",
      "scope:app",
      "layer:cli",
      "lang:ts"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm --dir apps/chitin-dashboard exec vite build",
          "cwd": "{workspaceRoot}"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -p apps/chitin-dashboard/tsconfig.json --noEmit",
          "cwd": "{workspaceRoot}"
        }
      },
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -p apps/chitin-dashboard/tsconfig.json --noEmit && pnpm --dir apps/chitin-dashboard exec vite build",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
