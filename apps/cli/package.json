{
  "name": "@chitin/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "bin": {
    "chitin": "./src/main.ts"
  },
  "scripts": {
    "test": "vitest run tests"
  },
  "nx": {
    "sourceRoot": "apps/cli/src",
    "projectType": "application",
    "tags": [
      "type:app",
      "scope:app",
      "layer:cli",
      "lang:ts"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run apps/cli/tests",
          "cwd": "{workspaceRoot}"
        }
      },
      "run": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsx apps/cli/src/main.ts",
          "cwd": "{workspaceRoot}"
        }
      },
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -b apps/cli/tsconfig.json && pnpm exec vitest run apps/cli/tests",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "^validate"
        ]
      }
    }
  },
  "dependencies": {
    "@chitin/contracts": "workspace:*",
    "@chitin/telemetry": "workspace:*",
    "commander": "*",
    "chokidar": "*"
  }
}
