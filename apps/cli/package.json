{
  "name": "@chitin/cli",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./src/main.ts",
  "bin": {
    "chitin": "./bin/chitin.js"
  },
  "files": [
    "bin",
    "src",
    "vendor"
  ],
  "scripts": {
    "test": "vitest run 000-boundary-coverage.test.ts tests"
  },
  "nx": {
    "sourceRoot": "apps/cli/src",
    "projectType": "application",
    "tags": [
      "type:app",
      "scope:app",
      "layer:cli",
      "lang:ts"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run apps/cli/000-boundary-coverage.test.ts apps/cli/tests",
          "cwd": "{workspaceRoot}"
        }
      },
      "run": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsx apps/cli/src/main.ts",
          "cwd": "{workspaceRoot}"
        }
      },
      "validate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsc -b apps/cli/tsconfig.json && pnpm exec vitest run apps/cli/000-boundary-coverage.test.ts apps/cli/tests",
          "cwd": "{workspaceRoot}"
        },
        "dependsOn": [
          "^validate"
        ]
      }
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "tsx": "^4.21.0",
    "commander": "*",
    "chokidar": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
