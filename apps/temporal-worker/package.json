{
  "name": "@chitin/temporal-worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/runner.ts",
  "bin": {
    "chitin-agent-runner": "./bin/chitin-agent-runner",
    "chitin-execute-request": "./bin/chitin-execute-request"
  },
  "scripts": {
    "submit": "tsx src/submit.ts",
    "runner": "tsx src/runner.ts",
    "execute-request": "tsx src/execute-request.ts",
    "test": "vitest run test"
  },
  "nx": {
    "tags": ["layer:app"],
    "targets": {
      "submit": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsx apps/temporal-worker/src/submit.ts",
          "cwd": "{workspaceRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec vitest run apps/temporal-worker/test",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {
    "@chitin/contracts": "workspace:*"
  }
}
