#!/usr/bin/env bash
# swarm/hooks/git-ops-recorder/reference-transaction
#
# Source for the git reference-transaction hook installed by
# swarm/bin/install-git-ops-recorder.sh. Records every git ref mutation
# (commit, checkout, reset, push, pull, fetch FETCH_HEAD updates,
# branch -D, tag, etc.) with process-tree attribution to a JSONL log.
#
# Why this exists: in May 2026 we observed several mystery reverts in
# this repo (spec.md, feature.json, CLAUDE.md reset to older values
# without an obvious local actor). The reflog showed the WHAT but not
# the WHO. This hook captures the caller's process tree at the moment
# of the mutation, so the next mystery revert leaves fingerprints.
#
# Format (one JSON line per phase):
#   {"ts":"<RFC3339Nano>", "event":"reference-transaction",
#    "phase":"prepared|committed|aborted",
#    "repo":"<absolute>", "cwd":"<absolute>",
#    "updates":[{"old":"<oid>","new":"<oid>","ref":"<refname>"}, ...],
#    "process_tree":[{"pid":N,"cmd":"<cmdline>"}, ...]}
#
# Best-effort: this hook MUST NEVER block or fail a git operation.
# Any write failure to the log is swallowed silently.

set -uo pipefail

PHASE="${1:-unknown}"

LOG_DIR="${CHITIN_GIT_OPS_LOG_DIR:-$HOME/.chitin}"
LOG="$LOG_DIR/git-ops.jsonl"
mkdir -p "$LOG_DIR" 2>/dev/null || exit 0

ts() {
    date -u +%Y-%m-%dT%H:%M:%S.%6NZ 2>/dev/null
}

# JSON-escape a string for inclusion as a string value (handles \ and ").
json_escape() {
    local s="${1-}"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    printf '%s' "$s"
}

# Read transaction updates from stdin. Each line is "<old> <new> <ref>".
updates=""
while IFS=' ' read -r old new ref; do
    [[ -z "${old-}" ]] && continue
    old_esc=$(json_escape "$old")
    new_esc=$(json_escape "$new")
    ref_esc=$(json_escape "$ref")
    entry=$(printf '{"old":"%s","new":"%s","ref":"%s"}' "$old_esc" "$new_esc" "$ref_esc")
    if [[ -z "$updates" ]]; then
        updates="$entry"
    else
        updates="$updates,$entry"
    fi
done
updates="[$updates]"

# Walk the process tree up to 6 levels. Each entry: {pid, cmd}.
proc_tree=""
pid=$$
levels=0
while [[ $levels -lt 6 && -n "$pid" && "$pid" != "0" && "$pid" != "1" ]]; do
    cmdline_file="/proc/$pid/cmdline"
    [[ ! -r "$cmdline_file" ]] && break
    cmd=$(tr '\0' ' ' < "$cmdline_file" 2>/dev/null | head -c 500)
    cmd_esc=$(json_escape "$cmd")
    entry=$(printf '{"pid":%d,"cmd":"%s"}' "$pid" "$cmd_esc")
    if [[ -z "$proc_tree" ]]; then
        proc_tree="$entry"
    else
        proc_tree="$proc_tree,$entry"
    fi

    stat_file="/proc/$pid/stat"
    [[ ! -r "$stat_file" ]] && break
    stat=$(cat "$stat_file" 2>/dev/null) || break
    [[ -z "$stat" ]] && break
    rest="${stat##*)}"
    read -r _ ppid _ <<< "$rest"
    [[ -z "${ppid:-}" ]] && break
    pid="$ppid"
    levels=$((levels + 1))
done
proc_tree="[$proc_tree]"

repo=$(git rev-parse --show-toplevel 2>/dev/null || printf '%s' "$PWD")
repo_esc=$(json_escape "$repo")
cwd_esc=$(json_escape "$PWD")

record=$(printf '{"ts":"%s","event":"reference-transaction","phase":"%s","repo":"%s","cwd":"%s","updates":%s,"process_tree":%s}' \
    "$(ts)" "$(json_escape "$PHASE")" "$repo_esc" "$cwd_esc" "$updates" "$proc_tree")

printf '%s\n' "$record" >> "$LOG" 2>/dev/null || true

exit 0
