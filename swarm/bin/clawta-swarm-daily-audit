#!/usr/bin/env bash
set -u

SCRIPT_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

BOARD="${KANBAN_BOARD:-${HERMES_KANBAN_BOARD:-}}"
if [[ -z "$BOARD" ]]; then
  BOARD="chitin"
  echo "clawta-swarm-daily-audit: defaulting to board 'chitin' because neither KANBAN_BOARD nor HERMES_KANBAN_BOARD was set. This legacy fallback is deprecated; set one explicitly." >&2
fi
export KANBAN_BOARD="$BOARD"

REPO_DIR="${CHITIN_REPO:-$(python3 "$SCRIPT_DIR/board_resolver.py" workspace)}"
REPO="${GITHUB_REPOSITORY:-$(python3 "$SCRIPT_DIR/board_resolver.py" repo)}"
cd "$REPO_DIR" 2>/dev/null || { echo "🦞 daily swarm audit: cannot cd to $REPO_DIR"; exit 1; }

now=$(TZ=America/Detroit date '+%Y-%m-%d %H:%M %Z')
echo "🦞 daily swarm audit — $now"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  branch=$(git branch --show-current 2>/dev/null || true)
  dirty=$(git status --short 2>/dev/null | wc -l | tr -d ' ')
  echo "- checkout: ${branch:-detached}; dirty entries: $dirty"
fi

echo "- open swarm/clawta PRs:"
if gh pr list --repo "$REPO" --state open --limit 30 --json number,title,headRefName,mergeable,statusCheckRollup,comments >/tmp/clawta-daily-prs.json 2>/tmp/clawta-daily-prs.err; then
  python3 - <<'PY'
import json, re
prs=json.load(open('/tmp/clawta-daily-prs.json'))
interesting=[p for p in prs if p.get('headRefName','').startswith(('swarm/','clawta/'))]
if not interesting:
    print('  - none')
for p in interesting[:15]:
    states=sorted(set((c.get('conclusion') or c.get('status') or c.get('state') or '').lower() for c in p.get('statusCheckRollup') or [] if (c.get('conclusion') or c.get('status') or c.get('state'))))
    if not states: checks='none'
    elif any(s in states for s in ['failure','failed','error','cancelled','timed_out','action_required']): checks='fail'
    elif any(s in states for s in ['pending','queued','in_progress','requested','waiting']): checks='pending'
    elif all(s in ['success','neutral','skipped'] for s in states): checks='pass'
    else: checks=','.join(states)
    comments='\n'.join(c.get('body','') for c in p.get('comments') or [])
    reviews=re.findall(r'\*\*Verdict:\*\*\s*(APPROVE|REQUEST_CHANGES|COMMENT)', comments, re.I)
    review=reviews[-1].upper() if reviews else 'none'
    print(f"  - #{p['number']} {p.get('headRefName')} — {checks}, {p.get('mergeable')}, review={review}: {p.get('title')}")
PY
else
  echo "  - gh pr list failed: $(tail -1 /tmp/clawta-daily-prs.err 2>/dev/null)"
fi

echo "- active/blocked board items:"
if hermes kanban --board "$BOARD" list >/tmp/clawta-daily-kanban.txt 2>/tmp/clawta-daily-kanban.err; then
  python3 - <<'PY'
from pathlib import Path
lines=Path('/tmp/clawta-daily-kanban.txt').read_text(errors='ignore').splitlines()
sel=[l.strip() for l in lines if any(s in l for s in [' in_progress ', ' blocked ', ' triage ', ' ready ', ' todo '])]
if not sel:
    print('  - none visible')
for line in sel[:20]:
    print('  - '+line)
if len(sel)>20:
    print(f'  - … {len(sel)-20} more')
PY
else
  echo "  - kanban list failed: $(tail -1 /tmp/clawta-daily-kanban.err 2>/dev/null)"
fi

if [ -x /home/red/.openclaw/bin/clawta-swarm-pr-owner-cron ]; then
  echo "- controller: pr-owner wrapper installed"
else
  echo "- controller: pr-owner wrapper missing"
fi
