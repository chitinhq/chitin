#!/usr/bin/env python3
"""mini-mention-listener — inbound @Mini bridge from agent-bus → MiniSession.nudge.

Sibling to swarm/bin/clawta-mention-listener. Closes the Discord-inbound gap
for Mini: Hermes already mirrors Discord ↔ agent-bus, so this listener polls
the bus for messages addressed to Mini, routes them to the right goal_id,
and calls MiniSession.nudge().

Spec: .specify/specs/039-mini-discord-inbound/spec.md (slice 1).
Routing: R1 (per-session thread binding) + B2 (first inbound binds).

Daemon mode (default) ticks every 60s. `--once` runs one batch and exits.
`--dry-run` lists addressed messages without nudging or marking read.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sqlite3
import sys
import time
from pathlib import Path
from typing import Any, Callable

# CHITIN_REPO: in-tree default uses parents[2] (repo root from swarm/bin/).
# install-mini-mention-listener.sh rewrites this line to an absolute path
# when copying into ~/.openclaw/bin/, where parents[2] would resolve to $HOME.
REPO = Path(__file__).resolve().parents[2]  # CHITIN_REPO
if str(REPO) not in sys.path:
    sys.path.insert(0, str(REPO))

from swarm.mini import MiniSession
from swarm.mini._internal import statedir as _statedir
from swarm.mini._internal.routing import (
    BoundThreadMismatch,
    ThreadAlreadyClaimed,
    bind_thread,
    route_message,
)

BUS_DB = Path(os.environ.get(
    "AGENT_BUS_DB", str(Path.home() / ".chitin" / "agent-bus" / "bus.db"),
))
AGENT = "mini"
SELF_AUTHOR = "Mini"
LOG_FILE = Path.home() / ".openclaw" / "logs" / "mini-mention-listener.log"
LIMIT_PER_TICK = int(os.environ.get("MINI_LISTENER_LIMIT_PER_TICK", "10"))
POLL_SECONDS = int(os.environ.get("MINI_LISTENER_POLL_SECONDS", "60"))

# Address-detection patterns. Mirrors clawta's shape; the Discord native
# mention ID is left as None until an operator wires up a Mini Discord
# identity. Text `@mini` and leading "Mini, ..." both work today.
#
# The second pattern requires addressing punctuation (comma, colon, hyphen,
# em-dash) after the "Mini" token — optionally separated by whitespace.
# An earlier version included `\s` in the trailing char class, which
# greedily matched any narrative sentence beginning with "Mini" (e.g.
# Ares replying "Mini is installed and ready"). The current shape only
# fires on operator-style addressing: "Mini, …", "Mini: …", "Mini — …".
_MENTION_PATTERNS = [
    re.compile(r"(?<![A-Za-z0-9_])@mini(?![A-Za-z0-9_-])", re.IGNORECASE),
    re.compile(r"^\s*Mini\b\s*[,:\-—]", re.MULTILINE),
]


def _log(msg: str) -> None:
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    ts = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    with LOG_FILE.open("a") as f:
        f.write(f"{ts} {msg}\n")


def _connect() -> sqlite3.Connection:
    conn = sqlite3.connect(str(BUS_DB))
    conn.row_factory = sqlite3.Row
    return conn


def _addressed_to_mini(row: Any) -> bool:
    """True iff this message addresses Mini."""
    if row["author"] == SELF_AUTHOR:
        return False
    audience = row["audience"] or ""
    members = {m.strip() for m in audience.split(",") if m.strip()}
    if AGENT in members or SELF_AUTHOR in members:
        return True
    body = row["body"] or ""
    return any(p.search(body) for p in _MENTION_PATTERNS)


def _unread_messages(conn: sqlite3.Connection) -> list[Any]:
    return conn.execute(
        """
        SELECT m.id, m.thread_id, m.author, m.body, m.audience,
               m.created_at, t.title AS thread_title
        FROM messages m
        JOIN threads t ON t.id = m.thread_id
        WHERE m.author != ?
          AND NOT EXISTS (
              SELECT 1 FROM reads r
              WHERE r.message_id = m.id AND r.agent_id = ?
          )
        ORDER BY m.id ASC
        LIMIT ?
        """,
        (SELF_AUTHOR, AGENT, LIMIT_PER_TICK * 4),
    ).fetchall()


def _mark_read(conn: sqlite3.Connection, message_id: int) -> None:
    conn.execute(
        "INSERT OR IGNORE INTO reads(agent_id, message_id, read_at) VALUES(?,?,?)",
        (AGENT, message_id, int(time.time())),
    )
    conn.commit()


def _post_reply(conn: sqlite3.Connection, *, thread_id: int, parent_id: int,
                body: str) -> int | None:
    now = int(time.time())
    cur = conn.execute(
        "INSERT INTO messages(thread_id, parent_id, author, body, kind, created_at) "
        "VALUES(?,?,?,?,?,?)",
        (thread_id, parent_id, SELF_AUTHOR, body, "message", now),
    )
    conn.execute("UPDATE threads SET updated_at=? WHERE id=?", (now, thread_id))
    conn.commit()
    return cur.lastrowid


def _audit(state_dir: Path, *, bus_msg_id: int, bus_thread_id: int,
           body: str, decision: str) -> None:
    """Append one row to <state_dir>/inbound.jsonl. AC6."""
    rec = {
        "ts": int(time.time()),
        "bus_msg_id": bus_msg_id,
        "bus_thread_id": bus_thread_id,
        "content_sha": hashlib.sha256((body or "").encode("utf-8")).hexdigest(),
        "decision": decision,
    }
    with (state_dir / "inbound.jsonl").open("a") as f:
        f.write(json.dumps(rec) + "\n")


def _default_factory(goal_id: str) -> MiniSession:
    return MiniSession(goal_id)


def _process_addressed(
    row: Any,
    *,
    conn: sqlite3.Connection,
    state_root: Path,
    mini_session_factory: Callable[[str], Any],
) -> str:
    """Process one addressed message. Returns the decision string."""
    body = row["body"] or ""
    bus_msg_id = row["id"]
    bus_thread_id = row["thread_id"]
    bus_thread_str = str(bus_thread_id)

    result = route_message(
        state_root=state_root, bus_thread_id=bus_thread_str, body=body,
    )

    if result.decision == "no_match":
        _log(f"no_match msg={bus_msg_id} thread={bus_thread_id}")
        _mark_read(conn, bus_msg_id)
        return "no_match"

    if result.decision == "ambiguous":
        candidates = ", ".join(f"`{c}`" for c in result.candidates)
        _post_reply(
            conn, thread_id=bus_thread_id, parent_id=bus_msg_id,
            body=(f"@mini routing is ambiguous — candidate goals: {candidates}. "
                  f"Reply naming exactly one goal id and I'll bind this thread."),
        )
        _mark_read(conn, bus_msg_id)
        _log(f"ambiguous msg={bus_msg_id} candidates={list(result.candidates)}")
        return "ambiguous"

    if result.decision == "collision":
        candidates = ", ".join(f"`{c}`" for c in result.candidates)
        _post_reply(
            conn, thread_id=bus_thread_id, parent_id=bus_msg_id,
            body=(f"@mini thread-binding collision — goals {candidates} both claim "
                  f"thread {bus_thread_id}. Operator must clear one of "
                  f"`<state_dir>/thread_id` before this thread routes again."),
        )
        _mark_read(conn, bus_msg_id)
        _log(f"collision msg={bus_msg_id} candidates={list(result.candidates)}")
        return "collision"

    # bound or first_inbound_bind: nudge path.
    assert result.goal_id is not None and result.state_dir is not None
    goal_id = result.goal_id
    state_dir = result.state_dir

    if result.decision == "first_inbound_bind":
        try:
            bind_thread(
                state_root=state_root, state_dir=state_dir,
                bus_thread_id=bus_thread_str,
            )
        except (BoundThreadMismatch, ThreadAlreadyClaimed) as exc:
            _audit(state_dir, bus_msg_id=bus_msg_id,
                   bus_thread_id=bus_thread_id, body=body, decision="error")
            _log(f"bind_failed msg={bus_msg_id} goal={goal_id} err={exc}")
            return "error"

    # AC3: nudge first; reply ONLY on success.
    try:
        session = mini_session_factory(goal_id)
        session.nudge(body)
    except Exception as exc:
        _audit(state_dir, bus_msg_id=bus_msg_id,
               bus_thread_id=bus_thread_id, body=body, decision="error")
        _log(f"nudge_failed msg={bus_msg_id} goal={goal_id} err={exc!r}")
        return "error"

    _audit(state_dir, bus_msg_id=bus_msg_id,
           bus_thread_id=bus_thread_id, body=body, decision="nudged")
    _post_reply(
        conn, thread_id=bus_thread_id, parent_id=bus_msg_id,
        body=f"📥 nudge delivered to `{goal_id}`",
    )
    _mark_read(conn, bus_msg_id)
    _log(f"nudged msg={bus_msg_id} goal={goal_id}")
    return "nudged"


def tick(
    *,
    conn: sqlite3.Connection | None = None,
    state_root: Path | None = None,
    mini_session_factory: Callable[[str], Any] | None = None,
) -> dict:
    """One poll cycle. Injectable for tests."""
    own_conn = False
    if conn is None:
        if not BUS_DB.is_file():
            _log(f"bus_db_missing: {BUS_DB}")
            return {"unread": 0, "addressed": 0, "nudged": 0, "errors": 0}
        conn = _connect()
        own_conn = True
    if state_root is None:
        state_root = _statedir.state_root()
    if mini_session_factory is None:
        mini_session_factory = _default_factory

    try:
        rows = _unread_messages(conn)
        addressed = [r for r in rows if _addressed_to_mini(r)]
        nudged = 0
        errors = 0

        for row in addressed[:LIMIT_PER_TICK]:
            decision = _process_addressed(
                row, conn=conn, state_root=state_root,
                mini_session_factory=mini_session_factory,
            )
            if decision == "nudged":
                nudged += 1
            elif decision == "error":
                errors += 1

        # Mark non-addressed messages read too, so we don't re-scan them forever.
        for row in rows:
            if not _addressed_to_mini(row):
                _mark_read(conn, row["id"])

        return {
            "unread": len(rows),
            "addressed": len(addressed),
            "nudged": nudged,
            "errors": errors,
        }
    finally:
        if own_conn:
            conn.close()


def catchup(conn: sqlite3.Connection | None = None) -> dict:
    """Mark every currently-unread bus message as read by Mini.

    For a fresh listener install: the bus has thousands of accumulated
    messages from before the listener existed. Without catchup the
    tick window (LIMIT_PER_TICK*4) drains the backlog at ~40/min,
    delaying real @mini messages by hours. Catchup snaps the read
    marker to the head of the bus so the first real tick sees only
    new traffic.

    Idempotent: INSERT OR IGNORE on the reads table. Safe to re-run
    when the listener has been offline and accumulated backlog again.
    Returns {"marked": N, "now_unread": M}.
    """
    own_conn = False
    if conn is None:
        if not BUS_DB.is_file():
            return {"marked": 0, "now_unread": 0, "note": f"bus_db_missing: {BUS_DB}"}
        conn = _connect()
        own_conn = True
    try:
        now = int(time.time())
        cur = conn.execute(
            """
            INSERT OR IGNORE INTO reads(message_id, agent_id, read_at)
            SELECT m.id, ?, ?
            FROM messages m
            WHERE m.author != ?
              AND NOT EXISTS (
                  SELECT 1 FROM reads r
                  WHERE r.message_id = m.id AND r.agent_id = ?
              )
            """,
            (AGENT, now, SELF_AUTHOR, AGENT),
        )
        marked = cur.rowcount
        conn.commit()
        now_unread = conn.execute(
            """
            SELECT COUNT(*) FROM messages m
            WHERE m.author != ?
              AND NOT EXISTS (
                  SELECT 1 FROM reads r
                  WHERE r.message_id = m.id AND r.agent_id = ?
              )
            """,
            (SELF_AUTHOR, AGENT),
        ).fetchone()[0]
        return {"marked": marked, "now_unread": now_unread}
    finally:
        if own_conn:
            conn.close()


def main() -> int:
    ap = argparse.ArgumentParser(prog="mini-mention-listener")
    ap.add_argument("--once", action="store_true",
                    help="Run one tick and exit (default: daemon loop)")
    ap.add_argument("--dry-run", action="store_true",
                    help="List addressed messages without nudging or marking read")
    ap.add_argument("--catchup", action="store_true",
                    help="Mark all currently-unread bus messages as read by mini "
                         "and exit. Used at install time to skip pre-existing backlog. "
                         "Idempotent.")
    args = ap.parse_args()

    if args.catchup:
        result = catchup()
        print(json.dumps(result, indent=2))
        return 0

    if args.dry_run:
        if not BUS_DB.is_file():
            print(json.dumps({"error": f"bus_db_missing: {BUS_DB}"}, indent=2))
            return 2
        conn = _connect()
        try:
            rows = _unread_messages(conn)
            addressed = [r for r in rows if _addressed_to_mini(r)]
            print(json.dumps({
                "unread": len(rows),
                "addressed": [
                    {"id": r["id"], "author": r["author"],
                     "thread_id": r["thread_id"],
                     "body": (r["body"] or "")[:120]}
                    for r in addressed
                ],
            }, indent=2))
        finally:
            conn.close()
        return 0

    if args.once:
        stats = tick()
        print(json.dumps(stats, indent=2))
        return 0

    while True:
        try:
            stats = tick()
            if stats["addressed"] or stats["errors"]:
                _log(f"tick stats={stats}")
        except Exception as exc:  # noqa: BLE001
            _log(f"tick_exception: {exc!r}")
        time.sleep(POLL_SECONDS)


if __name__ == "__main__":
    sys.exit(main())
