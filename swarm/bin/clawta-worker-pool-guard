#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BOARD="${KANBAN_BOARD:-chitin}"
_boards_dir="${HOME}/.hermes/kanban/boards"
if [[ -n "${KANBAN_DB:-}" ]]; then
  : # explicit path wins
else
  KANBAN_DB="${_boards_dir}/${BOARD}/kanban.db"
fi
export KANBAN_DB BOARD
if [[ -z "${KANBAN_BOARD:-}" && -z "${KANBAN_DB:-}" ]]; then
  echo "clawta-worker-pool-guard: defaulting to board 'chitin' because neither KANBAN_BOARD nor KANBAN_DB was set. This legacy fallback is deprecated; set one explicitly." >&2
fi
REPO_DIR="${CHITIN_REPO:-$(python3 "$SCRIPT_DIR/board_resolver.py" workspace)}"
cd "$REPO_DIR"
# Default: only claude-code is disabled (Anthropic ToS forbids it as a
# subagent). Copilot is governance-aware via `chitin-kernel drive copilot`
# (which uses the in-kernel Go SDK driver — the authority carve-out for
# agent=clawta is in gate_hook.go's isClawtaDriveCarveout). Override with
# CLAWTA_DISABLED_WORKER_LANES if a lane needs to be quarantined.
DISABLED_LANES=${CLAWTA_DISABLED_WORKER_LANES:-claude-code}
DISABLED_DIR=/home/red/.openclaw/data/agent-cards/disabled
mkdir -p "$DISABLED_DIR"
changed=()
IFS=',' read -r -a lanes <<< "$DISABLED_LANES"
for lane in "${lanes[@]}"; do
  lane="${lane// /}"
  [[ -n "$lane" ]] || continue
  card="/home/red/.openclaw/data/agent-cards/$lane.json"
  if [[ -f "$card" ]]; then
    ts=$(date +%Y%m%d-%H%M%S)
    mv "$card" "$DISABLED_DIR/$lane.json.disabled-$ts"
    changed+=("quarantined active agent card: $lane")
  fi
  while IFS=$'\t' read -r id st title; do
    [[ -n "${id:-}" ]] || continue
    ./scripts/kanban-flow block "$id" "$lane removed from autonomous worker pool; human-in-loop/operator only" --author clawta >/dev/null 2>&1 || true
    hermes kanban --board "$BOARD" assign "$id" red >/dev/null
    hermes kanban --board "$BOARD" comment "$id" --author clawta "$lane is disabled for autonomous dispatch; moved to red for human-in-loop/operator handling." >/dev/null || true
    changed+=("blocked $lane queue ticket: $id — $title")
  done < <(sqlite3 -tabs "$(eval echo "$KANBAN_DB")" "SELECT id,status,title FROM tasks WHERE status IN ('ready','todo') AND assignee='$lane' ORDER BY priority DESC, created_at ASC;")
done

if (( ${#changed[@]} )); then
  {
    echo "🦞 Worker-pool guard enforced disabled lane policy:"
    printf -- '- %s\n' "${changed[@]}"
  } | /home/red/.vite-plus/bin/openclaw message send --channel discord --account default --target channel:1503439202719760405 --text-file - >/dev/null 2>&1 || true
fi
printf 'worker pool guard: %d change(s)\n' "${#changed[@]}"
