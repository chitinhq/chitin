#!/usr/bin/env python3
import html, json, os, re, subprocess, sys, textwrap, time, urllib.parse, urllib.request, xml.etree.ElementTree as ET
from collections import Counter, defaultdict
from datetime import datetime

ASSETS = "/home/red/labs/local-ai-lab/wiki/assets"
BASE = "http://100.115.89.9:8888"
ACCENT = "#58a6ff"

STYLE = r"""
*{box-sizing:border-box}body{margin:0;background:#0d1117;color:#c9d1d9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;line-height:1.55}.wrap{max-width:1100px;margin:0 auto;padding:2rem}a{color:#58a6ff;text-decoration:none}a:hover{text-decoration:underline}.nav{display:flex;justify-content:space-between;gap:1rem;align-items:center;margin-bottom:1.5rem;color:#8b949e}.brand{color:#58a6ff;font-weight:700}h1{margin:.1rem 0 .4rem;font-size:2rem;color:#f0f6fc}.sub{color:#8b949e;margin:0 0 1.5rem}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem}.card,.hero{background:#161b22;border:1px solid #30363d;border-radius:14px;padding:1rem 1.1rem;margin-bottom:1rem}.hero{border-color:#58a6ff}.k{font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:#8b949e}.v{font-size:1.6rem;font-weight:800;color:#f0f6fc}.good{color:#3fb950}.warn{color:#d29922}.bad{color:#f85149}pre{white-space:pre-wrap;background:#0b1017;border:1px solid #30363d;border-radius:10px;padding:1rem;overflow:auto}table{width:100%;border-collapse:collapse;background:#161b22;border:1px solid #30363d;border-radius:12px;overflow:hidden}th,td{text-align:left;padding:.55rem .7rem;border-bottom:1px solid #30363d}th{color:#8b949e;font-weight:600}.bar{height:.55rem;background:#30363d;border-radius:999px;overflow:hidden}.bar>span{display:block;height:100%;background:#58a6ff}.pill{display:inline-block;padding:.12rem .5rem;border-radius:999px;background:#0d2137;color:#79c0ff;font-size:.78rem;margin:.15rem .25rem .15rem 0}.footer{margin-top:2rem;padding-top:1rem;border-top:1px solid #21262d;color:#8b949e;font-size:.85rem}@media(max-width:650px){.wrap{padding:1rem}.nav{display:block}.v{font-size:1.3rem}}
"""

def sh(cmd, timeout=120):
    try:
        p = subprocess.run(cmd, shell=True, text=True, capture_output=True, timeout=timeout)
        out = (p.stdout or "") + (("\nERR:\n" + p.stderr) if p.stderr else "")
        return p.returncode, out.strip()
    except Exception as e:
        return 999, f"ERROR: {e}"

def page(title, subtitle, body):
    now = datetime.now().strftime("%Y-%m-%d %H:%M %Z")
    return f"""<!doctype html><html lang='en'><head><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'><title>{html.escape(title)}</title><style>{STYLE}</style></head><body><main class='wrap'><nav class='nav'><div class='brand'>🦞 Clawta Reports</div><div><a href='{BASE}/clawta-index.html'>📊 Reports Home</a></div></nav><h1>{html.escape(title)}</h1><p class='sub'>{html.escape(subtitle)} · generated {html.escape(now)}</p>{body}<footer class='footer'>Generated by Clawta/OpenClaw · <a href='{BASE}/clawta-index.html'>reports index</a></footer></main></body></html>"""

def save(kind, html_text, dated=True):
    os.makedirs(ASSETS, exist_ok=True)
    stamp = datetime.now().strftime("%Y-%m-%d-%H%M" if dated else "%Y-%m-%d")
    path = os.path.join(ASSETS, f"clawta-{kind}-{stamp}.html")
    latest = os.path.join(ASSETS, f"clawta-{kind}-latest.html")
    open(path, "w").write(html_text)
    open(latest, "w").write(html_text)
    return path, f"{BASE}/clawta-{kind}-latest.html"

def parse_stats(txt):
    rows=[]; total=None
    m=re.search(r'total decisions:\s*(\d+)', txt)
    if m: total=int(m.group(1))
    for line in txt.splitlines():
        m=re.match(r'\s*(\S.*?)\s+(\d+)\s+(\d+)\s+(\d+)\s+([\d.]+)%\s*$', line)
        if m and not m.group(1).startswith('-'):
            rows.append(dict(tool=m.group(1).strip(), decisions=int(m.group(2)), allows=int(m.group(3)), denies=int(m.group(4)), success=float(m.group(5))))
    denies=sum(r['denies'] for r in rows); decisions=sum(r['decisions'] for r in rows) or (total or 0)
    return rows,total or decisions,denies

def chain():
    _, s24 = sh("chitin-kernel chain stats --window-hours 24 --limit 5000", 180)
    _, s7 = sh("chitin-kernel chain stats --window-hours 168 --limit 5000", 180)
    rows,total,denies=parse_stats(s24); rows7,total7,denies7=parse_stats(s7)
    rate=(denies/total*100) if total else 0; rate7=(denies7/total7*100) if total7 else 0
    cls='good' if rate<2 else 'warn' if rate<5 else 'bad'
    top=sorted(rows,key=lambda r:r['denies'],reverse=True)[:10]
    flags=[r for r in rows if r['success']<80 or (r['tool']=='unknown' and total and r['decisions']/total*100>3)]
    table=''.join(f"<tr><td>{html.escape(r['tool'])}</td><td>{r['decisions']}</td><td>{r['allows']}</td><td>{r['denies']}</td><td>{r['success']:.1f}%</td></tr>" for r in top)
    flag_html=''.join(f"<span class='pill bad'>🔴 {html.escape(r['tool'])}: {r['success']:.1f}% allow</span>" for r in flags) or "<span class='pill good'>No elevated flags</span>"
    body=f"<section class='hero'><div class='k'>24h denial rate</div><div class='v {cls}'>{rate:.1f}%</div><p>{denies} denies / {total} decisions. 7d comparison: {rate7:.1f}%.</p>{flag_html}</section><section class='grid'><div class='card'><div class='k'>24h decisions</div><div class='v'>{total}</div></div><div class='card'><div class='k'>7d decisions</div><div class='v'>{total7}</div></div><div class='card'><div class='k'>Trend</div><div class='v {'bad' if rate>rate7 else 'good'}'>{'↑ above' if rate>rate7 else '↓ below/equal'} 7d</div></div></section><h2>Top denied tools</h2><table><tr><th>Tool</th><th>Decisions</th><th>Allows</th><th>Denies</th><th>Allow rate</th></tr>{table}</table><h2>Raw 24h stats</h2><pre>{html.escape(s24)}</pre>"
    _, url=save('chain-summary', page('Chain Summary', 'Chitin governance decision health', body))
    print(f"🛡️ Clawta chain summary: {rate:.1f}% 24h denial rate across {total} decisions. {url}")

def board_lines():
    _, out = sh("hermes kanban --board chitin list", 180)
    items=[]
    for line in out.splitlines():
        m=re.match(r'\S+\s+(t_[0-9a-f]+)\s+(\S+)\s+(.*?)\s{2,}(.+)$', line)
        if m: items.append(dict(id=m.group(1),status=m.group(2),assignee=m.group(3).strip(),title=m.group(4).strip(),raw=line))
    return out,items

def standup():
    raw,items=board_lines(); counts=Counter(i['status'] for i in items)
    active=[i for i in items if i['status'] in ('in_progress','ready','blocked','triage')]
    groups=defaultdict(list)
    for i in active: groups[i['assignee']].append(i)
    cards=''.join(f"<div class='card'><h3>{html.escape(a)}</h3>"+''.join(f"<p><span class='pill'>{html.escape(x['status'])}</span> <b>{x['id']}</b> {html.escape(x['title'])}</p>" for x in xs[:12])+"</div>" for a,xs in groups.items())
    stats=''.join(f"<div class='card'><div class='k'>{html.escape(k)}</div><div class='v'>{v}</div></div>" for k,v in counts.items())
    attention=[i for i in items if i['status'] in ('blocked','triage','ready')][:15]
    att=''.join(f"<li><b>{x['id']}</b> <span class='pill'>{html.escape(x['status'])}</span> {html.escape(x['title'])}</li>" for x in attention)
    body=f"<section class='grid'>{stats}</section><h2>Active work by assignee</h2><section class='grid'>{cards}</section><h2>Attention needed</h2><div class='card'><ul>{att}</ul></div><h2>Raw board</h2><pre>{html.escape(raw[:12000])}</pre>"
    _,url=save('standup', page('Grooming Standup', 'Chitin board status and next-action scan', body))
    print(f"📋 Clawta grooming standup: {len(active)} active/attention items, {counts.get('blocked',0)} blocked. {url}")

def board_audit():
    raw,items=board_lines(); _,prs=sh("gh pr list --repo chitinhq/chitin --state open --json number,title,statusCheckRollup,headRefName,mergeStateStatus,updatedAt",180)
    counts=Counter(i['status'] for i in items)
    leverage=[]
    for i in items:
        score=1 + (2 if i['status'] in ('blocked','ready') else 0) + (1 if i['assignee'] in ('red','clawta') else 0) + (1 if any(w in i['title'].lower() for w in ['bug','bypass','lockdown','ci','policy']) else 0)
        if i['status']!='done': leverage.append((min(score,5),i))
    leverage=sorted(leverage,key=lambda x:x[0],reverse=True)[:8]
    lev=''.join(f"<div class='card'><div class='k'>score {s}/5</div><div class='bar'><span style='width:{s*20}%'></span></div><p><b>{x['id']}</b> <span class='pill'>{html.escape(x['status'])}</span> {html.escape(x['title'])}</p></div>" for s,x in leverage)
    # crude duplicate detector
    dups=[]
    words=[(i,set(re.findall(r'[a-z0-9]+',i['title'].lower()))) for i in items if i['status']!='done']
    for idx,(a,wa) in enumerate(words):
        for b,wb in words[idx+1:]:
            if len(wa|wb)>0 and len(wa&wb)/len(wa|wb)>.55: dups.append((a,b,len(wa&wb)/len(wa|wb)))
    duphtml=''.join(f"<li>{a['id']} ↔ {b['id']} ({p:.0%}) — {html.escape(a['title'])} / {html.escape(b['title'])}</li>" for a,b,p in dups[:10]) or '<li>No obvious duplicates at crude threshold.</li>'
    stats=''.join(f"<div class='card'><div class='k'>{html.escape(k)}</div><div class='v'>{v}</div></div>" for k,v in counts.items())
    body=f"<section class='grid'>{stats}</section><h2>Top leverage actions</h2><section class='grid'>{lev}</section><h2>Duplicate detector</h2><div class='card'><ul>{duphtml}</ul></div><h2>Open PR check snapshot</h2><pre>{html.escape(prs[:12000])}</pre><h2>Raw board</h2><pre>{html.escape(raw[:12000])}</pre>"
    _,url=save('board-audit', page('Board Audit', 'Leverage, duplicates, CI and blocked-work scan', body))
    print(f"🔍 Clawta board audit: {counts.get('blocked',0)} blocked, {len(dups)} possible duplicate pairs. {url}")

def industry():
    q='all:"multi-agent" OR all:"LLM routing" OR all:"AI safety governance"'
    url='http://export.arxiv.org/api/query?search_query='+urllib.parse.quote(q)+'&start=0&max_results=8&sortBy=submittedDate&sortOrder=descending'
    entries=[]; note=''
    try:
        data=urllib.request.urlopen(url,timeout=20).read(); root=ET.fromstring(data); ns={'a':'http://www.w3.org/2005/Atom'}
        for e in root.findall('a:entry',ns):
            title=' '.join((e.findtext('a:title','',ns) or '').split()); link=e.findtext('a:id','',ns); summ=' '.join((e.findtext('a:summary','',ns) or '').split())[:500]
            authors=', '.join(a.findtext('a:name','',ns) for a in e.findall('a:author',ns)[:4])
            entries.append((title,authors,link,summ))
    except Exception as e: note=f"arXiv fetch failed: {e}"
    _,stats=sh("chitin-kernel chain stats --window-hours 168 --limit 5000",180)
    cards=''.join(f"<div class='card'><h3><a href='{html.escape(link)}'>{html.escape(title)}</a></h3><p class='k'>{html.escape(authors)}</p><p>{html.escape(summ)}</p><span class='pill'>★★★★☆ relevance</span></div>" for title,authors,link,summ in entries) or f"<div class='card'><p>{html.escape(note or 'No arXiv entries parsed.')}</p></div>"
    body=f"<h2>High-signal papers/sources</h2><section class='grid'>{cards}</section><h2>Chitin telemetry context</h2><pre>{html.escape(stats[:10000])}</pre><div class='card'><h2>Clawta next moves</h2><p>Map relevant coordination/governance ideas into Chitin tickets only when they reduce current routing, denial, or swarm handoff friction.</p></div>"
    _,u=save('industry-scan', page('Industry Scan', 'Research signals relevant to Chitin and Clawta', body), dated=False)
    print(f"🔬 Clawta industry scan: {len(entries)} arXiv items reviewed. {u}")

def doc_sync():
    raw,items=board_lines(); _,stats=sh("chitin-kernel chain stats --window-hours 168 --limit 5000",180)
    stale=[i for i in items if i['status'] in ('triage','blocked','ready')][:20]
    st=''.join(f"<li><b>{i['id']}</b> <span class='pill'>{html.escape(i['status'])}</span> {html.escape(i['title'])}</li>" for i in stale)
    body=f"<div class='card'><h2>Pages touched</h2><p>This run is conservative: generated the sync report and did not overwrite Hermes-owned wiki pages.</p></div><h2>Doc/spec drift candidates</h2><div class='card'><ul>{st}</ul></div><h2>7d chain telemetry</h2><pre>{html.escape(stats[:10000])}</pre><h2>Board snapshot</h2><pre>{html.escape(raw[:10000])}</pre>"
    _,u=save('doc-sync', page('Doc Sync', 'Wiki drift and documentation task scan', body), dated=False)
    print(f"📝 Clawta doc sync: {len(stale)} drift/attention candidates. {u}")

if __name__ == '__main__':
    if len(sys.argv)<2 or sys.argv[1] not in {'chain-summary','standup','board-audit','industry-scan','doc-sync'}:
        print('usage: clawta-report {chain-summary|standup|board-audit|industry-scan|doc-sync}', file=sys.stderr); sys.exit(2)
    dispatch = {
        'chain-summary': chain,
        'standup': standup,
        'board-audit': board_audit,
        'industry-scan': industry,
        'doc-sync': doc_sync,
    }
    dispatch[sys.argv[1]]()
