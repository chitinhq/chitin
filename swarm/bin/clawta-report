def sh(cmd, timeout=120):
    try:
        p = subprocess.run(cmd, shell=True, text=True, capture_output=True, timeout=timeout)
        out = (p.stdout or "") + (("\nERR:\n" + p.stderr) if p.stderr else "")
        return p.returncode, out.strip()
    except Exception as e:
        return 999, f"ERROR: {e}"

def page(title, subtitle, body):
    now = datetime.now().strftime("%Y-%m-%d %H:%M %Z")
    return f"""<!doctype html><html lang='en'><head><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'><title>{html.escape(title)}</title><style>{STYLE}</style></head><body><main class='wrap'><nav class='nav'><div class='brand'>🦞 Clawta Reports</div><div><a href='{BASE}/clawta-index.html'>📊 Reports Home</a></div></nav><h1>{html.escape(title)}</h1><p class='sub'>{html.escape(subtitle)} · generated {html.escape(now)}</p>{body}<footer class='footer'>Generated by Clawta/OpenClaw · <a href='{BASE}/clawta-index.html'>reports index</a></footer></main></body></html>"""

def render_index():
    cards = []
    for report in REPORT_CARDS:
        tags = ''.join(f"<span class='pill'>{html.escape(tag)}</span>" for tag in report["tags"])
        cards.append(
            f"""<article class='index-card'><h2><a href='{report["href"]}'>{report["title"]}</a></h2><div class='schedule'>{html.escape(report["schedule"])}</div><p class='desc'>{html.escape(report["desc"])}</p>{tags}</article>"""
        )
    body = (
        "<header><div class='k'>Clawta</div><h1>Clawta Reports</h1>"
        "<p class='sub'>Dark HTML reports for Chitin swarm operations. Latest files are refreshed in place so operators can keep one stable URL per surface.</p></header>"
        f"<section class='index-grid'>{''.join(cards)}</section>"
        "<p class='small'><a href='index.html'>← Shared reports home</a></p>"
    )
    return page("Clawta Reports", "Static dashboards for Chitin swarm operations", body)

def update_index():
    os.makedirs(ASSETS, exist_ok=True)
    open(os.path.join(ASSETS, "clawta-index.html"), "w").write(render_index())

def save(kind, html_text, dated=True):
    os.makedirs(ASSETS, exist_ok=True)
    stamp = datetime.now().strftime("%Y-%m-%d-%H%M" if dated else "%Y-%m-%d")
    path = os.path.join(ASSETS, f"clawta-{kind}-{stamp}.html")
    latest = os.path.join(ASSETS, f"clawta-{kind}-latest.html")
    open(path, "w").write(html_text)
    open(latest, "w").write(html_text)
    update_index()
    return path, f"{BASE}/clawta-{kind}-latest.html"

def fmt_ts(ts):
    if not ts:
        return "—"
    return datetime.fromtimestamp(int(ts)).astimezone().strftime("%Y-%m-%d %H:%M")

def age_human(seconds):
    seconds = max(int(seconds), 0)
    days, rem = divmod(seconds, 86400)
    hours, rem = divmod(rem, 3600)
    mins = rem // 60
    if days:
        return f"{days}d {hours}h"
    if hours:
        return f"{hours}h {mins}m"
    return f"{mins}m"

def pill(text, tone=""):
    cls = f"pill {tone}".strip()
    return f"<span class='{cls}'>{html.escape(text)}</span>"

def active_dispatch_tickets():
    """Return unique ticket ids currently owned by dispatch roots/workers.

    Counts both early lobster workflow roots and long-lived `clawta dispatch
    ticket ...` roots. Child vendor CLIs are intentionally ignored so one
    worker is counted once.
    """
    # NOTE: raw string — the sed backreference \1 must reach sed intact. A
    # plain "" string turns \1 into the octal escape \x01, which silently
    # breaks ticket extraction (every row gets filtered out below).
    # The [[:space:]]* after the colon tolerates spaced --args-json JSON.
    code, out = sh(r"""{ (pgrep -af 'lobster run --mode tool --file /home/red/.openclaw/workflows/kanban-dispatch.lobster' 2>/dev/null || true) | grep -oE '"ticket_id":[[:space:]]*"t_[0-9a-f]+"' | sed -E 's/.*"(t_[0-9a-f]+)".*/\1/' || true; (pgrep -af '/home/red/.local/bin/clawta dispatch ticket t_[0-9a-f]+ to ' 2>/dev/null || true) | grep -oE 'dispatch ticket t_[0-9a-f]+' | awk '{print $3}' || true; } | sed '/^$/d' | sort -u""", 20)
    if code != 0:
        return []
    tickets = [line.strip() for line in out.splitlines() if re.match(r'^t_[0-9a-f]+$', line.strip())]
    return sorted(set(tickets))

def runtime_lane_cards():
    root = os.path.expanduser("~/.openclaw/data/agent-cards")
    lanes = {}
    for lane in sorted(TERMINAL_LANES):
        path = os.path.join(root, f"{lane}.json")
        if os.path.exists(path):
            try:
                data = json.load(open(path))
            except Exception:
                data = {}
            lanes[lane] = {"active": True, "models": [m.get("id", "?") for m in data.get("models", [])]}
        else:
            lanes[lane] = {"active": False, "models": []}
    return lanes

def projection_scenarios(queue_depth, active_count, max_active=1):
    remaining = max(queue_depth, 0)
    capacity = max(max_active, 1)
    # Workers already mid-flight occupy a lane for the first wave before the
    # queue can use it, so they flow through the same `capacity` lanes as
    # queued work. With active_count=0 this reduces to ceil(remaining/cap).
    in_flight = max(active_count, 0)
    waves = (remaining + in_flight + capacity - 1) // capacity
    scenarios = []
    for label, minutes in [("fast", 45), ("expected", 90), ("slow/sticky", 180)]:
        total_minutes = waves * minutes
        scenarios.append({
            "label": label,
            "worker_minutes": minutes,
            "eta_seconds": total_minutes * 60,
        })
    return scenarios

def board_conn():
    conn = sqlite3.connect(BOARD_DB)
    conn.row_factory = sqlite3.Row
    return conn

def open_prs():
    _, raw = sh("gh pr list --repo chitinhq/chitin --state open --json number,title,headRefName,state,mergeStateStatus,updatedAt,isDraft,statusCheckRollup", 180)
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return []

def pr_ticket_id(pr):
    match = re.search(r'([0-9a-f]{8})', pr.get('headRefName', ''))
    return f"t_{match.group(1)}" if match else None

def pr_check_summary(pr):
    rollup = pr.get("statusCheckRollup") or []
    failing = pending = success = 0
    for check in rollup:
        status = (check.get("status") or "").upper()
        conclusion = (check.get("conclusion") or "").upper()
        if status != "COMPLETED":
            pending += 1
        elif conclusion == "SUCCESS":
            success += 1
        else:
            failing += 1
    if failing:
        tone, label = "bad", "failing"
    elif pending:
        tone, label = "warn", "pending"
    else:
        tone, label = "good", "clean"
    return {"failing": failing, "pending": pending, "success": success, "tone": tone, "label": label}

def lifecycle_snapshot():
    code, raw = sh("cd /home/red/workspace/chitin && ./swarm/bin/clawta-pr-lifecycle --auto-merge --escalate-to red", 240)
    if code != 0:
        return {"items": [], "error": raw[:1000]}
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {"items": [], "error": raw[:1000]}

def merge_blockers(item):
    blockers = []
    if item.get("state") != "OPEN":
        return ["not open"]
    if item.get("ticket") is None:
        blockers.append("unmapped ticket")
    elif item.get("ticket_status") != "in_progress":
        blockers.append(f"ticket {item.get('ticket_status') or 'unknown'}")
    if item.get("mergeable") not in ("MERGEABLE", "CLEAN"):
        blockers.append(f"merge {item.get('mergeable') or 'unknown'}")
    if item.get("checks") != "pass":
        blockers.append(f"checks {item.get('checks') or 'unknown'}")
    review = item.get("review") or "none"
    if review != "APPROVE":
        blockers.append(f"review {review}")
    if not item.get("review_current_head"):
        blockers.append("review not current-head")
    if not blockers and not item.get("auto_merge_ready"):
        blockers.append(item.get("action") or "not lifecycle-ready")
    return blockers or ["ready"]

def load_board_state():
    conn = board_conn()
    cols = {row[1] for row in conn.execute("PRAGMA table_info(tasks)")}
    retry_cols = []
    retry_cols.append("consecutive_failures" if "consecutive_failures" in cols else "0 AS consecutive_failures")
    retry_cols.append("last_failure_error" if "last_failure_error" in cols else "NULL AS last_failure_error")
    retry_cols.append("block_reason" if "block_reason" in cols else "NULL AS block_reason")
    tasks = [dict(row) for row in conn.execute(
        "SELECT id, title, assignee, status, priority, created_at, started_at, completed_at, last_heartbeat_at, current_run_id, "
        + ", ".join(retry_cols)
        + " FROM tasks"
    )]
    comments = [dict(row) for row in conn.execute(
        "SELECT task_id, author, body, created_at FROM task_comments ORDER BY created_at"
    )]
    events = [dict(row) for row in conn.execute(
        "SELECT task_id, kind, payload, created_at, run_id FROM task_events ORDER BY created_at"
    )]
    runs = [dict(row) for row in conn.execute(
        "SELECT id, task_id, status, started_at, ended_at, outcome, last_heartbeat_at, summary FROM task_runs"
    )]
    conn.close()
    return tasks, comments, events, runs

def lifecycle_orphans():
    conn = board_conn()
    conn.row_factory = sqlite3.Row
    done_without_runs = [dict(row) for row in conn.execute(
        """
        SELECT t.id, t.title, t.assignee, t.completed_at
          FROM tasks t
         WHERE t.status = 'done'
           AND NOT EXISTS (
                 SELECT 1
                   FROM task_runs r
                  WHERE r.task_id = t.id
               )
         ORDER BY t.completed_at DESC, t.id DESC
        """
    )]
    runs_without_ticket = [dict(row) for row in conn.execute(
        """
        SELECT r.id, r.task_id, r.status, r.started_at, r.ended_at, r.outcome, r.summary
          FROM task_runs r
          LEFT JOIN tasks t
            ON t.id = r.task_id
         WHERE t.id IS NULL
         ORDER BY r.started_at DESC, r.id DESC
        """
    )]
    conn.close()
    return {
        "done_without_runs": done_without_runs,
        "runs_without_ticket": runs_without_ticket,
    }

def complexity_map_from_comments(comments):
    result = {}
    for row in comments:
        match = re.search(r'complexity\s+(low|med|high)', row['body'], re.I)
        if match:
            result[row['task_id']] = match.group(1).lower()
    return result

def compute_complexity_elo(scores, complexity_map):
    grouped = defaultdict(list)
    for row in scores:
        grouped[(row["driver"], row["model"], complexity_map.get(row["ticket_id"], "unknown"))].append(row)
    rows = []
    for (driver, model, complexity), group in grouped.items():
        rating = BASE_ELO
        count = 0
        for item in sorted(group, key=lambda r: (r["scored_at"], r["ticket_id"])):
            k = BASE_K / (1.0 + count / K_DECAY_AT_N)
            norm = max(-1.0, min(1.0, (int(item["total_score"]) - 15.0) / 10.0))
            rating += k * norm
            count += 1
        avg_score = sum(int(item["total_score"]) for item in group) / len(group)
        rows.append({
            "driver": driver,
            "model": model,
            "complexity": complexity,
            "elo_score": rating,
            "dispatches_count": len(group),
            "avg_score": avg_score,
            "last_ticket_id": max(group, key=lambda r: r["scored_at"])["ticket_id"],
            "last_scored_at": max(group, key=lambda r: r["scored_at"])["scored_at"],
        })
    return sorted(rows, key=lambda r: (r["elo_score"], r["dispatches_count"]), reverse=True)

BLOCK_REASON_META = {
    "needs-fix": {"owner": "clawta", "tone": "warn", "action": "Clawta re-dispatches/fixes once with review context"},
    "needs-rebase": {"owner": "clawta", "tone": "warn", "action": "Clawta rebases and reruns lifecycle"},
    "no-pr": {"owner": "hermes", "tone": "warn", "action": "Hermes/board engine opens or repairs PR creation"},
    "retry-exhausted": {"owner": "hermes", "tone": "bad", "action": "Hermes diagnoses after retry budget exhaustion"},
    "explicit-failure": {"owner": "hermes", "tone": "bad", "action": "Hermes diagnoses traceback/failing worker context"},
    "silent-death": {"owner": "clawta", "tone": "warn", "action": "Watchdog retries up to budget, then escalates"},
    "ci-fail": {"owner": "clawta", "tone": "bad", "action": "Clawta dispatches CI-fix worker once"},
    "pr-rejected": {"owner": "hermes", "tone": "bad", "action": "Hermes reviews rejection and decides retry/spec change"},
    "deploy-drift": {"owner": "clawta", "tone": "warn", "action": "Clawta restores deployed/repo sync or clean branch"},
    "operator-decision": {"owner": "red", "tone": "bad", "action": "Red/operator decision required"},
    "dep-gate": {"owner": "hermes", "tone": "warn", "action": "Auto-unblock when dependency clears"},
    "poller-oscillation": {"owner": "hermes", "tone": "bad", "action": "Hermes stabilizes queue/poller state"},
}


def block_reason_meta(reason):
    reason = (reason or "").strip()
    if not reason:
        return {"owner": "unknown", "tone": "", "action": "no structured block reason recorded"}
    return BLOCK_REASON_META.get(reason, {"owner": "unknown", "tone": "warn", "action": "unrecognized block_reason; inspect Hermes vocabulary"})


def classify_stuck_ticket(task, *, pr=None, active=False, stale_note=""):
    """Turn a vague stuck row into an operator/controller action bucket."""
    assignee = task.get("assignee") or ""
    failures = int(task.get("consecutive_failures") or 0)
    block_reason = (task.get("block_reason") or "").strip()
    if block_reason:
        meta = block_reason_meta(block_reason)
        return {
            "bucket": f"block:{block_reason}",
            "tone": meta["tone"],
            "action": meta["action"],
        }
    if pr:
        return {
            "bucket": "has-pr",
            "tone": "good",
            "action": "PR lifecycle owns this; review/fix/rebase/merge from the PR queue",
        }
    if assignee == "red":
        return {
            "bucket": "operator-owned",
            "tone": "warn",
            "action": "waiting on red/operator decision",
        }
    if active:
        return {
            "bucket": "active-worker",
            "tone": "good",
            "action": "worker still running; monitor heartbeat/logs",
        }
    if failures >= 2:
        return {
            "bucket": "retry-exhausting",
            "tone": "bad",
            "action": "near/exhausted watchdog retries; escalate or re-spec",
        }
    if stale_note:
        return {
            "bucket": "watchdog-flagged",
            "tone": "bad",
            "action": "watchdog already flagged it; inspect comment and repair/retry",
        }
    if assignee in TERMINAL_LANES or assignee == ROUTING_LANE:
        return {
            "bucket": "retryable-silent",
            "tone": "warn",
            "action": "no PR/worker seen; eligible for watchdog retry",
        }
    return {
        "bucket": "idle-unknown",
        "tone": "warn",
        "action": "needs classification; inspect board events and logs",
    }


def load_swarm_health():
    tasks, comments, events, runs = load_board_state()
    prs = open_prs()
    pr_by_ticket = {}
    for pr in prs:
        ticket = pr_ticket_id(pr)
        if ticket:
            pr_by_ticket[ticket] = pr
    task_by_id = {task["id"]: task for task in tasks}

    now = int(time.time())
    day_start = int(datetime.now().astimezone().replace(hour=0, minute=0, second=0, microsecond=0).timestamp())
    latest_event = {}
    latest_in_progress = {}
    for event in events:
        latest_event[event["task_id"]] = max(latest_event.get(event["task_id"], 0), int(event["created_at"]))
        if event["kind"] == "status_transition":
            try:
                payload = json.loads(event["payload"] or "{}")
            except json.JSONDecodeError:
                payload = {}
            if payload.get("to") == "in_progress":
                latest_in_progress[event["task_id"]] = max(
                    latest_in_progress.get(event["task_id"], 0),
                    int(event["created_at"]),
                )

    dispatch_attempts = []
    for event in events:
        if event["kind"] != "status_transition" or int(event["created_at"]) < day_start:
            continue
        try:
            payload = json.loads(event["payload"] or "{}")
        except json.JSONDecodeError:
            payload = {}
        if payload.get("to") != "in_progress":
            continue
        task = task_by_id.get(event["task_id"])
        if not task:
            continue
        dispatch_attempts.append({
            "id": task["id"],
            "title": task["title"],
            "assignee": task["assignee"] or "(unassigned)",
            "status": task["status"],
            "created_at": int(event["created_at"]),
            "pr": pr_by_ticket.get(task["id"]),
        })
    dispatch_attempts.sort(key=lambda row: row["created_at"], reverse=True)
    dispatched_today = []
    seen_dispatch = set()
    for row in dispatch_attempts:
        if row["id"] in seen_dispatch:
            continue
        seen_dispatch.add(row["id"])
        dispatched_today.append(row)

    stuck = []
    task_comments = defaultdict(list)
    for comment in comments:
        task_comments[comment["task_id"]].append(comment)
    runs_by_task = defaultdict(list)
    for run in runs:
        runs_by_task[run["task_id"]].append(run)
    active_tickets = active_dispatch_tickets()
    active_ticket_set = set(active_tickets)
    for task in tasks:
        if task["status"] != "in_progress":
            continue
        last_evt = latest_event.get(task["id"], task["started_at"] or task["created_at"] or now)
        last_hb = task["last_heartbeat_at"] or (
            max((r["last_heartbeat_at"] or 0) for r in runs_by_task[task["id"]]) if runs_by_task[task["id"]] else 0
        )
        idle_seconds = now - max(last_evt, last_hb or 0)
        in_progress_since = latest_in_progress.get(task["id"], task["started_at"] or task["created_at"] or 0)
        stale_markers = [
            c for c in task_comments[task["id"]]
            if c["created_at"] >= in_progress_since
            and re.search(r'(stale-worker watchdog|blocked:\s*stale|stale in_progress)', c["body"], re.I)
        ]
        if idle_seconds < 5400 and not stale_markers:
            continue
        stale_note = stale_markers[-1]["body"] if stale_markers else ""
        pr = pr_by_ticket.get(task["id"])
        classification = classify_stuck_ticket(
            task,
            pr=pr,
            active=task["id"] in active_ticket_set,
            stale_note=stale_note,
        )
        stuck.append({
            "id": task["id"],
            "title": task["title"],
            "assignee": task["assignee"] or "(unassigned)",
            "started_at": task["started_at"] or task["created_at"],
            "idle_seconds": idle_seconds,
            "last_event_at": last_evt,
            "stale_note": stale_note,
            "pr": pr,
            "consecutive_failures": int(task.get("consecutive_failures") or 0),
            "block_reason": task.get("block_reason") or "",
            "bucket": classification["bucket"],
            "bucket_tone": classification["tone"],
            "next_action": classification["action"],
        })
    stuck.sort(key=lambda row: (bool(row["pr"]), row["idle_seconds"]), reverse=True)

    blocked_red = []
    for task in tasks:
        if task["status"] == "blocked" and (task["assignee"] or "") == "red":
            reason = task.get("block_reason") or ""
            meta = block_reason_meta(reason)
            blocked_red.append({
                "id": task["id"],
                "title": task["title"],
                "priority": task["priority"] or 0,
                "blocked_at": latest_event.get(task["id"], task["created_at"]),
                "age_seconds": now - latest_event.get(task["id"], task["created_at"]),
                "block_reason": reason,
                "block_owner": meta["owner"],
                "block_tone": meta["tone"],
                "block_action": meta["action"],
            })
    blocked_red.sort(key=lambda row: (row["priority"], row["age_seconds"]), reverse=True)

    pr_lifecycle = []
    for pr in prs:
        summary = pr_check_summary(pr)
        pr_lifecycle.append({
            "ticket_id": pr_ticket_id(pr) or "—",
            "number": pr["number"],
            "title": pr["title"],
            "head": pr["headRefName"],
            "is_draft": pr.get("isDraft", False),
            "merge_state": pr.get("mergeStateStatus") or "UNKNOWN",
            "updated_at": pr.get("updatedAt"),
            "checks": summary,
        })
    pr_lifecycle.sort(key=lambda row: row["updated_at"], reverse=True)

    elo_conn = sqlite3.connect(ELO_DB)
    elo_conn.row_factory = sqlite3.Row
    score_rows = [dict(row) for row in elo_conn.execute(
        "SELECT ticket_id, driver, model, task_class, total_score, scored_at FROM swarm_dispatch_scores ORDER BY scored_at"
    )]
    elo_rows = compute_complexity_elo(score_rows, complexity_map_from_comments(comments))
    elo_conn.close()

    runtime_lanes = runtime_lane_cards()
    enabled_lanes = {lane for lane, meta in runtime_lanes.items() if meta["active"]}
    dispatchable = [
        task for task in tasks
        if task["status"] in ("ready", "todo")
        and (task["assignee"] or "") in enabled_lanes.union({ROUTING_LANE})
    ]
    # Current OpenClaw cron is intentionally conservative; keep the report honest
    # even if no env is available inside the static report runner.
    max_active = int(os.environ.get("CLAWTA_MAX_ACTIVE_WORKERS", "1"))
    projections = projection_scenarios(len(dispatchable), len(active_tickets), max_active=max_active)

    lifecycle = lifecycle_snapshot()
    merge_blocker_rows = []
    for item in lifecycle.get("items", []):
        if item.get("state") != "OPEN":
            continue
        blockers = merge_blockers(item)
        merge_blocker_rows.append({
            "pr": item.get("pr"),
            "url": item.get("url"),
            "ticket": item.get("ticket") or "—",
            "ticket_status": item.get("ticket_status") or "—",
            "checks": item.get("checks") or "unknown",
            "review": item.get("review") or "none",
            "mergeable": item.get("mergeable") or "unknown",
            "action": item.get("action") or "wait",
            "blockers": blockers,
        })
    merge_blocker_rows.sort(key=lambda row: (row["blockers"] == ["ready"], int(row["pr"] or 0)), reverse=True)

    return {
        "tasks": tasks,
        "dispatched_today": dispatched_today,
        "dispatch_attempts": dispatch_attempts,
        "stuck": stuck,
        "stuck_buckets": dict(Counter(row["bucket"] for row in stuck)),
        "blocked_red": blocked_red,
        "blocked_red_reasons": dict(Counter((row["block_reason"] or "unclassified") for row in blocked_red)),
        "pr_lifecycle": pr_lifecycle,
        "elo_rows": elo_rows,
        "dispatchable_queue": dispatchable,
        "active_dispatch_tickets": active_tickets,
        "runtime_lanes": runtime_lanes,
        "max_active_workers": max_active,
        "projections": projections,
        "merge_blockers": merge_blocker_rows,
        "lifecycle_error": lifecycle.get("error", ""),
    }

def parse_stats(txt):
    rows=[]; total=None
    m=re.search(r'total decisions:\s*(\d+)', txt)
    if m: total=int(m.group(1))
    for line in txt.splitlines():
        m=re.match(r'\s*(\S.*?)\s+(\d+)\s+(\d+)\s+(\d+)\s+([\d.]+)%\s*$', line)
        if m and not m.group(1).startswith('-'):
            rows.append(dict(tool=m.group(1).strip(), decisions=int(m.group(2)), allows=int(m.group(3)), denies=int(m.group(4)), success=float(m.group(5))))
    denies=sum(r['denies'] for r in rows); decisions=sum(r['decisions'] for r in rows) or (total or 0)
    return rows,total or decisions,denies

def chain():
    _, s24 = sh("chitin-kernel chain stats --window-hours 24 --limit 5000", 180)
    _, s7 = sh("chitin-kernel chain stats --window-hours 168 --limit 5000", 180)
    rows,total,denies=parse_stats(s24); rows7,total7,denies7=parse_stats(s7)
    rate=(denies/total*100) if total else 0; rate7=(denies7/total7*100) if total7 else 0
    cls='good' if rate<2 else 'warn' if rate<5 else 'bad'
    top=sorted(rows,key=lambda r:r['denies'],reverse=True)[:10]
    flags=[r for r in rows if r['success']<80 or (r['tool']=='unknown' and total and r['decisions']/total*100>3)]
    table=''.join(f"<tr><td>{html.escape(r['tool'])}</td><td>{r['decisions']}</td><td>{r['allows']}</td><td>{r['denies']}</td><td>{r['success']:.1f}%</td></tr>" for r in top)
    flag_html=''.join(f"<span class='pill bad'>🔴 {html.escape(r['tool'])}: {r['success']:.1f}% allow</span>" for r in flags) or "<span class='pill good'>No elevated flags</span>"
    body=f"<section class='hero'><div class='k'>24h denial rate</div><div class='v {cls}'>{rate:.1f}%</div><p>{denies} denies / {total} decisions. 7d comparison: {rate7:.1f}%.</p>{flag_html}</section><section class='grid'><div class='card'><div class='k'>24h decisions</div><div class='v'>{total}</div></div><div class='card'><div class='k'>7d decisions</div><div class='v'>{total7}</div></div><div class='card'><div class='k'>Trend</div><div class='v {'bad' if rate>rate7 else 'good'}'>{'↑ above' if rate>rate7 else '↓ below/equal'} 7d</div></div></section><h2>Top denied tools</h2><table><tr><th>Tool</th><th>Decisions</th><th>Allows</th><th>Denies</th><th>Allow rate</th></tr>{table}</table><h2>Raw 24h stats</h2><pre>{html.escape(s24)}</pre>"
    _, url=save('chain-summary', page('Chain Summary', 'Chitin governance decision health', body))
    print(f"🛡️ Clawta chain summary: {rate:.1f}% 24h denial rate across {total} decisions. {url}")

def board_lines():
    _, out = sh("hermes kanban --board chitin list", 180)
    items=[]
    for line in out.splitlines():
        m=re.match(r'\S+\s+(t_[0-9a-f]+)\s+(\S+)\s+(.*?)\s{2,}(.+)$', line)
        if m: items.append(dict(id=m.group(1),status=m.group(2),assignee=m.group(3).strip(),title=m.group(4).strip(),raw=line))
    return out,items

def standup():
    raw,items=board_lines(); counts=Counter(i['status'] for i in items)
    active=[i for i in items if i['status'] in ('in_progress','ready','blocked','triage')]
    groups=defaultdict(list)
    for i in active: groups[i['assignee']].append(i)
    cards=''.join(f"<div class='card'><h3>{html.escape(a)}</h3>"+''.join(f"<p><span class='pill'>{html.escape(x['status'])}</span> <b>{x['id']}</b> {html.escape(x['title'])}</p>" for x in xs[:12])+"</div>" for a,xs in groups.items())
    stats=''.join(f"<div class='card'><div class='k'>{html.escape(k)}</div><div class='v'>{v}</div></div>" for k,v in counts.items())
    attention=[i for i in items if i['status'] in ('blocked','triage','ready')][:15]
    att=''.join(f"<li><b>{x['id']}</b> <span class='pill'>{html.escape(x['status'])}</span> {html.escape(x['title'])}</li>" for x in attention)
    body=f"<section class='grid'>{stats}</section><h2>Active work by assignee</h2><section class='grid'>{cards}</section><h2>Attention needed</h2><div class='card'><ul>{att}</ul></div><h2>Raw board</h2><pre>{html.escape(raw[:12000])}</pre>"
    _,url=save('standup', page('Grooming Standup', 'Chitin board status and next-action scan', body))
    print(f"📋 Clawta grooming standup: {len(active)} active/attention items, {counts.get('blocked',0)} blocked. {url}")

def board_audit():
    raw,items=board_lines(); _,prs=sh("gh pr list --repo chitinhq/chitin --state open --json number,title,statusCheckRollup,headRefName,mergeStateStatus,updatedAt",180)
    counts=Counter(i['status'] for i in items)
    leverage=[]
    for i in items:
        score=1 + (2 if i['status'] in ('blocked','ready') else 0) + (1 if i['assignee'] in ('red','clawta') else 0) + (1 if any(w in i['title'].lower() for w in ['bug','bypass','lockdown','ci','policy']) else 0)
        if i['status']!='done': leverage.append((min(score,5),i))
    leverage=sorted(leverage,key=lambda x:x[0],reverse=True)[:8]
    lev=''.join(f"<div class='card'><div class='k'>score {s}/5</div><div class='bar'><span style='width:{s*20}%'></span></div><p><b>{x['id']}</b> <span class='pill'>{html.escape(x['status'])}</span> {html.escape(x['title'])}</p></div>" for s,x in leverage)
    # crude duplicate detector
    dups=[]
    words=[(i,set(re.findall(r'[a-z0-9]+',i['title'].lower()))) for i in items if i['status']!='done']
    for idx,(a,wa) in enumerate(words):
        for b,wb in words[idx+1:]:
            if len(wa|wb)>0 and len(wa&wb)/len(wa|wb)>.55: dups.append((a,b,len(wa&wb)/len(wa|wb)))
    duphtml=''.join(f"<li>{a['id']} ↔ {b['id']} ({p:.0%}) — {html.escape(a['title'])} / {html.escape(b['title'])}</li>" for a,b,p in dups[:10]) or '<li>No obvious duplicates at crude threshold.</li>'
    stats=''.join(f"<div class='card'><div class='k'>{html.escape(k)}</div><div class='v'>{v}</div></div>" for k,v in counts.items())
    body=f"<section class='grid'>{stats}</section><h2>Top leverage actions</h2><section class='grid'>{lev}</section><h2>Duplicate detector</h2><div class='card'><ul>{duphtml}</ul></div><h2>Open PR check snapshot</h2><pre>{html.escape(prs[:12000])}</pre><h2>Raw board</h2><pre>{html.escape(raw[:12000])}</pre>"
    _,url=save('board-audit', page('Board Audit', 'Leverage, duplicates, CI and blocked-work scan', body))
    print(f"🔍 Clawta board audit: {counts.get('blocked',0)} blocked, {len(dups)} possible duplicate pairs. {url}")

def board_watchdog():
    orphan_data = lifecycle_orphans()
    done_without_runs = orphan_data["done_without_runs"]
    runs_without_ticket = orphan_data["runs_without_ticket"]
    total_orphans = len(done_without_runs) + len(runs_without_ticket)
    tone = "good" if total_orphans == 0 else "bad"

    done_rows = ''.join(
        f"<tr><td class='mono'>{html.escape(row['id'])}</td><td>{html.escape(row['title'])}</td><td>{html.escape(row['assignee'] or '(unassigned)')}</td><td>{fmt_ts(row['completed_at'])}</td></tr>"
        for row in done_without_runs[:20]
    ) or "<tr><td colspan='4'>No done tickets are missing task_runs rows.</td></tr>"

    run_rows = ''.join(
        f"<tr><td>{row['id']}</td><td class='mono'>{html.escape(row['task_id'])}</td><td>{html.escape(row['status'])}</td><td>{fmt_ts(row['started_at'])}</td><td>{fmt_ts(row['ended_at'])}</td><td>{html.escape(row['outcome'] or '—')}</td></tr>"
        for row in runs_without_ticket[:20]
    ) or "<tr><td colspan='6'>No orphaned task_runs rows were found.</td></tr>"

    body = (
        "<section class='hero'>"
        "<div class='k'>Board Watchdog</div>"
        f"<div class='v {tone}'>{total_orphans} orphaned lifecycle link(s)</div>"
        "<p>Flags tickets in <span class='mono'>done</span> with no <span class='mono'>task_runs</span> row, and <span class='mono'>task_runs</span> rows whose ticket no longer exists.</p>"
        "</section>"
        "<section class='grid'>"
        + f"<div class='card'><div class='k'>Done Without Runs</div><div class='v {'good' if not done_without_runs else 'bad'}'>{len(done_without_runs)}</div></div>"
        + f"<div class='card'><div class='k'>Runs Without Ticket</div><div class='v {'good' if not runs_without_ticket else 'bad'}'>{len(runs_without_ticket)}</div></div>"
        + "</section>"
        + f"<div class='card'><div class='section-head'><h2>Done Tickets Missing task_runs</h2><span class='small muted'>terminal state without ledger bridge</span></div><table><tr><th>Ticket</th><th>Title</th><th>Assignee</th><th>Completed</th></tr>{done_rows}</table></div>"
        + f"<div class='card'><div class='section-head'><h2>task_runs Rows Missing Ticket</h2><span class='small muted'>run ledger without kanban owner</span></div><table><tr><th>Run</th><th>Task</th><th>Status</th><th>Started</th><th>Ended</th><th>Outcome</th></tr>{run_rows}</table></div>"
    )
    _, url = save('board-watchdog', page('Board Watchdog', 'Lifecycle orphan detection across kanban and run ledger', body))
    print(f"🚨 Clawta board watchdog: {len(done_without_runs)} done tickets without runs, {len(runs_without_ticket)} orphaned runs. {url}")

def industry():
    q='all:"multi-agent" OR all:"LLM routing" OR all:"AI safety governance"'
    url='http://export.arxiv.org/api/query?search_query='+urllib.parse.quote(q)+'&start=0&max_results=8&sortBy=submittedDate&sortOrder=descending'
    entries=[]; note=''
    try:
        data=urllib.request.urlopen(url,timeout=20).read(); root=ET.fromstring(data); ns={'a':'http://www.w3.org/2005/Atom'}
        for e in root.findall('a:entry',ns):
            title=' '.join((e.findtext('a:title','',ns) or '').split()); link=e.findtext('a:id','',ns); summ=' '.join((e.findtext('a:summary','',ns) or '').split())[:500]
            authors=', '.join(a.findtext('a:name','',ns) for a in e.findall('a:author',ns)[:4])
            entries.append((title,authors,link,summ))
    except Exception as e: note=f"arXiv fetch failed: {e}"
    _,stats=sh("chitin-kernel chain stats --window-hours 168 --limit 5000",180)
    cards=''.join(f"<div class='card'><h3><a href='{html.escape(link)}'>{html.escape(title)}</a></h3><p class='k'>{html.escape(authors)}</p><p>{html.escape(summ)}</p><span class='pill'>★★★★☆ relevance</span></div>" for title,authors,link,summ in entries) or f"<div class='card'><p>{html.escape(note or 'No arXiv entries parsed.')}</p></div>"
    body=f"<h2>High-signal papers/sources</h2><section class='grid'>{cards}</section><h2>Chitin telemetry context</h2><pre>{html.escape(stats[:10000])}</pre><div class='card'><h2>Clawta next moves</h2><p>Map relevant coordination/governance ideas into Chitin tickets only when they reduce current routing, denial, or swarm handoff friction.</p></div>"
    _,u=save('industry-scan', page('Industry Scan', 'Research signals relevant to Chitin and Clawta', body), dated=False)
    print(f"🔬 Clawta industry scan: {len(entries)} arXiv items reviewed. {u}")

