#!/usr/bin/env bash
set -u

SCRIPT_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

BOARD="${KANBAN_BOARD:-}"
if [[ "${1:-}" == "--board" ]]; then
  BOARD="${2:-}"
  shift 2
elif [[ "${1:-}" == --board=* ]]; then
  BOARD="${1#--board=}"
  shift
fi
if [[ -z "$BOARD" ]]; then
  BOARD="chitin"
  echo "clawta-pr-ci-triage: defaulting to board 'chitin' because neither --board nor KANBAN_BOARD was set. This legacy fallback is deprecated; set one explicitly." >&2
fi
export KANBAN_BOARD="$BOARD"

if [ $# -lt 1 ]; then
  echo "usage: clawta-pr-ci-triage [--board <slug>] <pr-number>" >&2
  exit 2
fi
PR="$1"
REPO="${GITHUB_REPOSITORY:-$(python3 "$SCRIPT_DIR/board_resolver.py" repo)}"
REPO_DIR="${CHITIN_REPO:-$(python3 "$SCRIPT_DIR/board_resolver.py" workspace)}"
cd "$REPO_DIR" 2>/dev/null || { echo "cannot cd to $REPO_DIR" >&2; exit 1; }

echo "🦞 CI triage for PR #$PR"

if ! gh pr view "$PR" --repo "$REPO" --json number,title,headRefName,headRefOid,mergeable,statusCheckRollup >/tmp/clawta-ci-pr.json 2>/tmp/clawta-ci-pr.err; then
  echo "- failed to read PR: $(tail -1 /tmp/clawta-ci-pr.err)"
  exit 1
fi
python3 - <<'PY'
import json
j=json.load(open('/tmp/clawta-ci-pr.json'))
print(f"- title: {j['title']}")
print(f"- branch: {j['headRefName']} @ {j['headRefOid'][:12]}; mergeable={j.get('mergeable')}")
items=j.get('statusCheckRollup') or []
if not items:
    print('- checks: none')
else:
    for c in items:
        state=(c.get('conclusion') or c.get('status') or c.get('state') or 'UNKNOWN')
        name=c.get('name') or c.get('workflowName') or c.get('__typename') or 'check'
        url=c.get('detailsUrl') or ''
        print(f"- check: {name} — {state}" + (f" ({url})" if url else ''))
PY

# Extract failed workflow run IDs from check URLs, then print failed logs.
python3 - <<'PY' >/tmp/clawta-ci-failed-runs.txt
import json,re
j=json.load(open('/tmp/clawta-ci-pr.json'))
seen=[]
for c in j.get('statusCheckRollup') or []:
    state=(c.get('conclusion') or c.get('status') or c.get('state') or '').upper()
    if state not in {'FAILURE','FAILED','ERROR','CANCELLED','TIMED_OUT','ACTION_REQUIRED'}:
        continue
    url=c.get('detailsUrl') or ''
    m=re.search(r'/actions/runs/(\d+)', url)
    if m and m.group(1) not in seen:
        seen.append(m.group(1))
print('\n'.join(seen))
PY

if [ ! -s /tmp/clawta-ci-failed-runs.txt ]; then
  echo "- failed-run logs: none (no failing workflow-run checks detected)"
  exit 0
fi

while read -r run_id; do
  [ -n "$run_id" ] || continue
  echo "- failed log snippets for run $run_id:"
  if gh run view "$run_id" --repo "$REPO" --log-failed >/tmp/clawta-ci-run.log 2>/tmp/clawta-ci-run.err; then
    python3 - <<'PY'
from pathlib import Path
lines=Path('/tmp/clawta-ci-run.log').read_text(errors='ignore').splitlines()
needles=('error','failed','failure','traceback','panic','not found','no such file','exit code')
hits=[]
for i,l in enumerate(lines):
    low=l.lower()
    if any(n in low for n in needles):
        start=max(0,i-3); end=min(len(lines),i+8)
        block='\n'.join(lines[start:end])
        if block not in hits:
            hits.append(block)
for block in hits[:4]:
    print('```')
    print('\n'.join(x[-240:] for x in block.splitlines()))
    print('```')
if not hits:
    print('  - no obvious error lines found in failed log')
PY
  else
    echo "  - failed to fetch log: $(tail -1 /tmp/clawta-ci-run.err)"
  fi
done </tmp/clawta-ci-failed-runs.txt
