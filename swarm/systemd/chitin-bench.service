[Unit]
Description=Chitin Bench terminal-bench continuous loop (spec 068)
Documentation=file:///home/red/workspace/chitin/.specify/specs/068-chitin-bench-loop-revival/spec.md
After=network-online.target ollama.service
Wants=ollama.service

[Service]
Type=simple
ExecStart=/home/red/workspace/chitin/swarm/bin/chitin-bench-loop
Restart=always
RestartSec=30
# Bench load is best-effort: yield CPU to interactive/agent work.
Nice=10
# A single bench task is wall-clock-capped at 1800s inside the runner;
# never let systemd kill a tick mid-flight.
TimeoutStopSec=120

[Install]
WantedBy=default.target
