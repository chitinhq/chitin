{
  "$schema": "http://json-schema.org/schema",
  "title": "observation",
  "description": "Generate an observation doc in docs/observations/",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Document identifier (kebab-case)",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "Document id (kebab-case, e.g. my-finding):"
    },
    "title": {
      "type": "string",
      "description": "Document title (defaults to title-cased id)"
    },
    "lens": {
      "type": "string",
      "description": "Active soul/lens during observation",
      "default": "da Vinci"
    },
    "status": {
      "type": "string",
      "description": "Document status",
      "default": "in-progress"
    },
    "type": {
      "type": "string",
      "description": "Observation type (e.g. post-mortem, ab-test, research, findings)",
      "default": "observation"
    }
  },
  "required": ["id"]
}
