{
  "$schema": "http://json-schema.org/schema",
  "title": "spec",
  "description": "Generate a design spec in docs/superpowers/specs/",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Document identifier (kebab-case)",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "Document id (kebab-case, e.g. my-feature):"
    },
    "title": {
      "type": "string",
      "description": "Document title (defaults to title-cased id)"
    },
    "lens": {
      "type": "string",
      "description": "Active soul/lens during design",
      "default": "da Vinci"
    },
    "status": {
      "type": "string",
      "description": "Document status",
      "default": "draft"
    },
    "supersedes": {
      "type": "string",
      "description": "What this document supersedes (use '—' for nothing)",
      "default": "—"
    },
    "tldr": {
      "type": "string",
      "description": "One-sentence TL;DR / thesis",
      "default": ""
    }
  },
  "required": ["id"]
}
