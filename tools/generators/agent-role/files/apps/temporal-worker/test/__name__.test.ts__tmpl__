// Stub tests for the `<%= name %>` role prompt builder.
// Generated by `nx g @chitin/agent-role:agent-role <%= name %> --shape <%= shape %>`.
// These invariants capture the load-bearing properties of the template;
// expand them as the prompt matures.

import { describe, expect, it } from 'vitest';
import { build<%= className %>Prompt } from '../src/<%= name %>/prompt.ts';
import type { BacklogEntry } from '../src/grooming/parse-backlog.ts';

function makeEntry(overrides: Partial<BacklogEntry> = {}): BacklogEntry {
  return {
    id: '<%= name %>-test-1',
    status: 'ready',
    role: '<%= name %>',
    description: 'Test entry for the <%= name %> role.',
    rawFrontmatter: '',
    rawSection: '',
    ...overrides,
  };
}

describe('build<%= className %>Prompt', () => {
  it('names the role', () => {
    const prompt = build<%= className %>Prompt(makeEntry());
    expect(prompt).toContain('<%= name %>');
  });

  it('surfaces the entry id in the output', () => {
    const prompt = build<%= className %>Prompt(makeEntry({ id: 'e-42' }));
    expect(prompt).toContain('e-42');
  });

  it('surfaces the entry description verbatim', () => {
    const detail = 'Investigate the <%= name %> signal at https://example.com';
    const prompt = build<%= className %>Prompt(makeEntry({ description: detail }));
    expect(prompt).toContain(detail);
  });

  it('produces a non-trivial output (length > 100 chars)', () => {
    expect(build<%= className %>Prompt(makeEntry()).length).toBeGreaterThan(100);
  });

  it('cites the factory design doc', () => {
    const prompt = build<%= className %>Prompt(makeEntry());
    expect(prompt).toContain('docs/design/2026-05-02-swarm-as-software-factory.md');
  });
<% if (shape === 'reviewer') { %>
  it('declares read-only constraint', () => {
    expect(build<%= className %>Prompt(makeEntry())).toMatch(/read-only/i);
  });

  it('contains the structured output marker', () => {
    expect(build<%= className %>Prompt(makeEntry())).toContain('<<<REVIEW>>>');
  });
<% } else if (shape === 'patcher') { %>
  it('cites the do-not-dismiss-as-noise rule (PR #78 precedent)', () => {
    expect(build<%= className %>Prompt(makeEntry())).toMatch(/do NOT dismiss as noise/i);
  });

  it('forbids dismissal without source-of-truth citation', () => {
    expect(build<%= className %>Prompt(makeEntry())).toMatch(/DISMISS without.*citation.*forbidden/i);
  });

  it('contains the structured output marker', () => {
    expect(build<%= className %>Prompt(makeEntry())).toContain('<<<PATCH_RESPONSE>>>');
  });
<% } else if (shape === 'analyst') { %>
  it('names the recipe-driven workflow (determinism-first model)', () => {
    expect(build<%= className %>Prompt(makeEntry())).toContain('python3 -m analysis.investigate');
  });

  it('contains the structured output marker', () => {
    expect(build<%= className %>Prompt(makeEntry())).toContain('<<<ANALYSIS>>>');
  });

  it('forbids authoring bespoke Python', () => {
    expect(build<%= className %>Prompt(makeEntry())).toMatch(/Do NOT author Python/i);
  });
<% } else { %>
  it('mentions external signal fetching', () => {
    expect(build<%= className %>Prompt(makeEntry())).toMatch(/fetch|signal|external/i);
  });

  it('contains the structured output marker', () => {
    expect(build<%= className %>Prompt(makeEntry())).toContain('<<<CANDIDATES>>>');
  });

  it('forbids direct roadmap edits', () => {
    expect(build<%= className %>Prompt(makeEntry())).toMatch(/Do NOT edit roadmap\.md directly/i);
  });
<% } %>
});
