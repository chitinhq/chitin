# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
!.github/instructions/chitin-*.instructions.md

.claude/worktrees
.claude/settings.local.json
.nx/polygraphdist/

# Chitin runtime state (captured events, session state, init marker)
.chitin/

# Go kernel build artifacts
/go/execution-kernel/chitin-kernel

# Graphify intermediate state (only wiki/ + GRAPH_REPORT.md are tracked; the rest regenerates)
graphify-out/.graphify_*
graphify-out/cache/
graphify-out/cost.json
graphify-out/manifest.json
graphify-out/graph.html
graphify-out/graph.json

# Analysis stream outputs
python/analysis/out/
bench/out/

# Python build / venv artifacts
python/analysis/*.egg-info/
python/analysis/.pytest_cache/
python/argus/*.egg-info/
python/argus/.pytest_cache/
python/argus/build/
__pycache__/
*.pyc

# Minnie/Octi per-goal session state (never committed) — spec 038
.swarm/

.angular

# Icarus terminal-bench runtime output — the non-stop loop writes here
# continuously (spec 068)
jobs/

# Local agent identity file (per-machine, never committed)
.chitin-identity

# gstack tool state (browse-startup logs + tmp/)
.gstack/

# Playwright MCP scratch directory (console logs, page snapshots — local-only)
.playwright-mcp/
